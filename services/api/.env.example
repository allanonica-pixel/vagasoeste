# ============================================================
# VagasOeste API — Variáveis de ambiente
# Copie para .env e preencha com os valores reais.
# NUNCA commite o .env real.
# ============================================================

# Ambiente: "development" | "staging" | "production"
NODE_ENV=development

# Porta local (Fly.io usa 8080 por padrão)
PORT=3000

# ----- Supabase -----
# URL do projeto (ex: https://xyzabc.supabase.co)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave anon — para leitura pública (listagem de vagas)
SUPABASE_ANON_KEY=eyJ...

# Chave service_role — NUNCA exponha no frontend!
# Usada pela API para bypassar RLS em operações de sistema
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# String de conexão direta ao Postgres (para Drizzle)
# Formato: postgres://usuario:senha@host:5432/postgres
DATABASE_URL=postgres://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ----- CORS -----
# Origens permitidas separadas por vírgula
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173,https://santarem.app,https://app.santarem.app

# ----- Segurança -----
# Segredo para assinar tokens internos (mín. 32 chars aleatórios)
API_SECRET=gere_com_openssl_rand_base64_32

# ----- Ambiente (staging vs prod) -----
# Prefixo de log: "api-dev" | "api-staging" | "api-prod"
LOG_LABEL=api-dev
