# ============================================================
# apps/site — Variáveis de ambiente (Astro)
# Copie para .env e preencha com os valores do ambiente correto.
# NUNCA commite o .env real — está no .gitignore.
# ============================================================

# ----- DEV (local) -----
# PUBLIC_SUPABASE_URL=https://<PROJECT_REF_DEV_OLD>.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=eyJ...  (anon key do projeto vagasoeste-dev)
# PUBLIC_SITE_URL=http://localhost:4321
# PUBLIC_APP_URL=http://localhost:5173

# ----- PRODUÇÃO -----
# PUBLIC_SUPABASE_URL=https://<PROJECT_REF_PROD>.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=eyJ...  (anon key do projeto vagasoeste prod)
# PUBLIC_SITE_URL=https://santarem.app
# PUBLIC_APP_URL=https://app.santarem.app

# ============================================================
# Preencha abaixo com os valores do ambiente que está usando:
# ============================================================

PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ_SUBSTITUA
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_APP_URL=http://localhost:5173
