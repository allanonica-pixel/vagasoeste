{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/plataforma/:path*",
      "destination": "https://app.vagasoeste.com.br/plataforma/:path*"
    },
    {
      "source": "/empresa/:path*",
      "destination": "https://app.vagasoeste.com.br/empresa/:path*"
    },
    {
      "source": "/login",
      "destination": "https://app.vagasoeste.com.br/login"
    },
    {
      "source": "/cadastro/:path*",
      "destination": "https://app.vagasoeste.com.br/cadastro/:path*"
    },
    {
      "source": "/verificar-email",
      "destination": "https://app.vagasoeste.com.br/verificar-email"
    },
    {
      "source": "/curriculo-avulso/:path*",
      "destination": "https://app.vagasoeste.com.br/curriculo-avulso/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
