---
import NavbarMobile from '../islands/NavbarMobile';

interface Props {
  /** Quando true, navbar começa transparente (home) e fica branca ao rolar */
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navLinks = [
  { label: 'Vagas', href: '/vagas' },
  { label: 'Blog', href: '/blog' },
  { label: 'Crie seu Currículo', href: '/crie-seu-curriculo' },
  { label: 'Como Funciona', href: '/como-funciona' },
  { label: 'Para Empresas', href: '/para-empresas' },
];

const currentPath = Astro.url.pathname;
---

<!-- Navbar Desktop — HTML puro, zero JS -->
<header
  id="navbar"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent ? 'navbar-transparent' : 'bg-white border-b border-gray-100',
  ]}
  data-transparent={transparent}
>
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
        <i class="ri-briefcase-line text-sm text-white"></i>
      </div>
      <span class="font-bold text-lg tracking-tight navbar-logo-text">
        Vagas<span class="navbar-logo-accent text-emerald-600">Oeste</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Navegação principal">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors whitespace-nowrap navbar-link',
            currentPath === link.href
              ? 'text-emerald-600'
              : 'text-gray-600 hover:text-gray-900',
          ]}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTAs Desktop -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="https://app.santarem.app/login"
        class="text-sm font-medium px-4 py-2 rounded-md border border-gray-200 hover:bg-gray-50 text-gray-700 transition-colors whitespace-nowrap navbar-btn-secondary"
      >
        Entrar
      </a>
      <a
        href="https://app.santarem.app/cadastro"
        class="text-sm font-semibold px-4 py-2 rounded-md bg-emerald-600 hover:bg-emerald-700 text-white transition-colors whitespace-nowrap"
      >
        Cadastrar-se
      </a>
    </div>

    <!-- Mobile: ilha React para interatividade do hambúrguer -->
    <NavbarMobile client:load navLinks={navLinks} />
  </div>
</header>

<!-- Script: navbar scroll effect para quando transparent=true -->
{transparent && (
  <script>
    const navbar = document.getElementById('navbar');
    if (navbar) {
      const updateNav = () => {
        if (window.scrollY > 60) {
          navbar.classList.remove('navbar-transparent');
          navbar.classList.add('bg-white', 'border-b', 'border-gray-100');
          navbar.querySelectorAll('.navbar-link').forEach((el) => {
            el.classList.remove('text-white/90', 'hover:text-white');
            el.classList.add('text-gray-600', 'hover:text-gray-900');
          });
          navbar.querySelectorAll('.navbar-logo-text').forEach((el) => {
            el.classList.remove('text-white');
            el.classList.add('text-gray-900');
          });
          navbar.querySelectorAll('.navbar-logo-accent').forEach((el) => {
            el.classList.remove('text-emerald-300');
            el.classList.add('text-emerald-600');
          });
          navbar.querySelectorAll('.navbar-btn-secondary').forEach((el) => {
            el.classList.remove('text-white', 'border-white/40', 'hover:bg-white/10');
            el.classList.add('text-gray-700', 'border-gray-200', 'hover:bg-gray-50');
          });
        } else {
          navbar.classList.add('navbar-transparent');
          navbar.classList.remove('bg-white', 'border-b', 'border-gray-100');
          navbar.querySelectorAll('.navbar-link').forEach((el) => {
            el.classList.add('text-white/90', 'hover:text-white');
            el.classList.remove('text-gray-600', 'hover:text-gray-900');
          });
          navbar.querySelectorAll('.navbar-logo-text').forEach((el) => {
            el.classList.add('text-white');
            el.classList.remove('text-gray-900');
          });
          navbar.querySelectorAll('.navbar-logo-accent').forEach((el) => {
            el.classList.add('text-emerald-300');
            el.classList.remove('text-emerald-600');
          });
          navbar.querySelectorAll('.navbar-btn-secondary').forEach((el) => {
            el.classList.add('text-white', 'border-white/40', 'hover:bg-white/10');
            el.classList.remove('text-gray-700', 'border-gray-200', 'hover:bg-gray-50');
          });
        }
      };

      // Aplicar estado inicial
      updateNav();
      window.addEventListener('scroll', updateNav, { passive: true });
    }
  </script>
)}

<style>
  .navbar-transparent {
    background: transparent;
  }

  .navbar-transparent .navbar-link {
    color: rgba(255,255,255,0.9);
  }
  .navbar-transparent .navbar-link:hover {
    color: white;
  }
  .navbar-transparent .navbar-logo-text {
    color: white;
  }
  .navbar-transparent .navbar-logo-accent {
    color: #6ee7b7; /* emerald-300 */
  }
  .navbar-transparent .navbar-btn-secondary {
    color: white;
    border-color: rgba(255,255,255,0.4);
  }
  .navbar-transparent .navbar-btn-secondary:hover {
    background-color: rgba(255,255,255,0.1);
  }
</style>
