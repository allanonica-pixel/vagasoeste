---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/islands/FAQAccordion';

export const prerender = true;

const steps = [
  { icon: 'ri-mail-send-line', title: 'Entre em contato', desc: 'Preencha o formulário de interesse ou fale direto com nossa equipe pelo WhatsApp.' },
  { icon: 'ri-user-settings-line', title: 'Receba suas credenciais', desc: 'Nossa equipe cria sua conta e envia as credenciais de acesso por email.' },
  { icon: 'ri-briefcase-4-line', title: 'Publique suas vagas', desc: 'Acesse o painel, crie vagas com detalhes completos e ative com 1 clique.' },
  { icon: 'ri-group-line', title: 'Receba candidatos', desc: 'Candidatos anonimizados chegam no painel. Veja perfil profissional, nunca dados pessoais.' },
  { icon: 'ri-filter-3-line', title: 'Selecione e filtre', desc: 'Filtre por formação, disponibilidade e pretensão salarial. Favorite os melhores perfis.' },
  { icon: 'ri-handshake-line', title: 'VagasOeste intermedia', desc: 'Solicite pré-entrevista ou contato. Nossa equipe executa e acompanha até a contratação.' },
];

const features = [
  { icon: 'ri-shield-user-line', title: 'Candidatos verificados', desc: 'Todos os perfis passam por validação básica pela VagasOeste antes de chegar no seu painel.' },
  { icon: 'ri-eye-off-line', title: 'Empresa sempre anônima', desc: 'Candidatos não sabem quem é sua empresa. Processo mais justo, baseado em competências.' },
  { icon: 'ri-filter-line', title: 'Filtros avançados', desc: 'Filtre candidatos por formação, sexo, PCD, bairro, disponibilidade e pretensão salarial.' },
  { icon: 'ri-history-line', title: 'Histórico de status', desc: 'Cada mudança de status é registrada com data e observação. Auditoria completa do processo.' },
  { icon: 'ri-notification-badge-line', title: 'Notificações em tempo real', desc: 'Receba alertas quando novos candidatos se inscreverem nas suas vagas.' },
  { icon: 'ri-bar-chart-line', title: 'Relatórios detalhados', desc: 'Veja candidaturas por vaga, setor, escolaridade e taxa de conversão por período.' },
];

const plans = [
  {
    name: 'Básico',
    price: 'Gratuito',
    desc: 'Para empresas que estão começando',
    features: ['1 vaga ativa', 'Até 20 candidatos/mês', 'Painel básico', 'Suporte por email'],
    cta: 'Começar grátis',
    highlight: false,
  },
  {
    name: 'Profissional',
    price: 'R$ 149/mês',
    desc: 'Para empresas em crescimento',
    features: ['Até 5 vagas ativas', 'Candidatos ilimitados', 'Filtros avançados', 'Suporte prioritário', 'Relatórios mensais'],
    cta: 'Falar com a equipe',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: 'Sob consulta',
    desc: 'Para grandes volumes de contratação',
    features: ['Vagas ilimitadas', 'Candidatos ilimitados', 'API de integração', 'Gerente dedicado', 'SLA garantido'],
    cta: 'Falar com a equipe',
    highlight: false,
  },
];

const testimonials = [
  { name: 'Supermercado Central', role: 'Gerente de RH', text: 'Contratamos 8 funcionários nos últimos 3 meses. O processo anônimo melhora muito a qualidade das candidaturas.' },
  { name: 'Clínica São Lucas', role: 'Administrador', text: 'A VagasOeste intermediou todo o processo. Economizamos muito tempo e encontramos profissionais qualificados.' },
  { name: 'Construtora Paraense', role: 'Diretor', text: 'Plataforma simples e eficiente. O filtro por bairro e disponibilidade é exatamente o que precisávamos.' },
];

const faqItems = [
  { question: 'Como minha empresa se cadastra?', answer: 'Sua empresa não se cadastra sozinha. Entre em contato conosco pelo formulário ou WhatsApp. Nossa equipe cria a conta e envia as credenciais. Isso garante a qualidade das empresas na plataforma.' },
  { question: 'Quantas vagas posso publicar?', answer: 'Depende do plano escolhido. No plano básico, 1 vaga ativa. No profissional, até 5. No Enterprise, ilimitado. Fale conosco para detalhes.' },
  { question: 'Vejo os dados pessoais dos candidatos?', answer: 'Não. Para proteger os candidatos, você vê apenas o perfil profissional: bairro, formação, experiência, pretensão salarial e disponibilidade. Nunca nome, email ou telefone.' },
  { question: 'Como funciona a pré-entrevista?', answer: 'Quando você identifica um candidato de interesse, solicita uma pré-entrevista pelo painel. Nossa equipe entra em contato com o candidato e coordena a conversa, preservando o anonimato até a etapa final.' },
  { question: 'Posso pausar uma vaga temporariamente?', answer: 'Sim. No painel "Minhas Vagas" você pode pausar, reativar ou encerrar qualquer vaga a qualquer momento.' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'VagasOeste para Empresas',
  description: 'Plataforma de recrutamento para empresas em Santarém/PA com candidatos verificados e processo intermediado.',
  provider: {
    '@type': 'Organization',
    name: 'VagasOeste',
    url: 'https://santarem.app',
  },
  areaServed: {
    '@type': 'Place',
    name: 'Santarém, Pará, Brasil',
  },
};
---

<BaseLayout
  title="Para Empresas — Recrutamento em Santarém PA | VagasOeste"
  description="Contrate profissionais em Santarém/PA com processo seletivo intermediado, candidatos verificados e total anonimato. Planos a partir de R$0."
  keywords="contratar funcionários Santarém, recrutamento Pará, vagas empresas Santarém, RH Santarém, contratar CLT Pará"
  schema={serviceSchema}
>

  <!-- Hero -->
  <section class="relative pt-24 pb-16 overflow-hidden" aria-label="Para Empresas">
    <div class="absolute inset-0">
      <img
        src="https://readdy.ai/api/search-image?query=professional%20business%20team%20meeting%20office%20Santarem%20Para%20Brazil%20warm%20light%20hiring%20recruitment%20modern%20workspace%20handshake%20corporate&width=1920&height=500&seq=para-empresas-hero&orientation=landscape"
        alt="Recrutamento para empresas em Santarém"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-emerald-950/78"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6">
      <nav aria-label="breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1.5 text-xs text-emerald-300">
          <li><a href="/" class="hover:text-white transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-white font-medium">Para Empresas</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <p class="text-xs font-semibold text-emerald-300 uppercase tracking-wide mb-3">Para Empresas</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">
          Contrate os melhores profissionais<br class="hidden md:block" />
          <span class="text-emerald-300">de Santarém e região</span>
        </h1>
        <p class="text-white/80 text-sm md:text-base mb-8 leading-relaxed max-w-lg">
          Processo de recrutamento intermediado, candidatos verificados e anonimato garantido. Do anúncio à contratação, cuidamos de tudo.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/interesse-empresa" class="btn-primary">
            <i class="ri-chat-1-line"></i>
            Falar com a equipe
          </a>
          <a href="/como-funciona" class="btn-outline-white">
            <i class="ri-information-line"></i>
            Como funciona
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Etapas do processo -->
  <section class="py-16 bg-white" aria-labelledby="processo-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Processo simplificado</p>
        <h2 id="processo-title" class="text-2xl font-bold text-gray-900">Como contratar pela VagasOeste</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {steps.map((step, i) => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 relative">
            <span class="absolute top-4 right-4 text-2xl font-bold text-gray-200">0{i+1}</span>
            <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <i class={`${step.icon} text-emerald-600 text-xl`}></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recursos do painel -->
  <section class="py-16 bg-gray-50" aria-labelledby="recursos-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Tecnologia a favor da sua empresa</p>
        <h2 id="recursos-title" class="text-2xl font-bold text-gray-900">Recursos do Painel Empresarial</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <i class={`${f.icon} text-2xl text-emerald-600 mb-3 block`}></i>
            <h3 class="font-semibold text-gray-900 mb-2">{f.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Planos -->
  <section class="py-16 bg-white" aria-labelledby="planos-title">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Investimento</p>
        <h2 id="planos-title" class="text-2xl font-bold text-gray-900">Planos para Empresas</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {plans.map((plan) => (
          <div class={`rounded-2xl p-7 border-2 ${plan.highlight ? 'border-emerald-500 bg-emerald-50 relative' : 'border-gray-200 bg-white'}`}>
            {plan.highlight && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-emerald-600 text-white text-xs font-bold px-4 py-1 rounded-full">
                Mais popular
              </span>
            )}
            <h3 class="font-bold text-gray-900 text-lg mb-1">{plan.name}</h3>
            <p class="text-xs text-gray-500 mb-3">{plan.desc}</p>
            <p class="text-2xl font-bold text-emerald-600 mb-5">{plan.price}</p>
            <ul class="space-y-2 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <i class="ri-check-line text-emerald-500 shrink-0"></i>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/interesse-empresa"
              class={`btn-${plan.highlight ? 'primary' : 'secondary'} w-full justify-center`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="py-16 bg-gray-50" aria-labelledby="depoimentos-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <h2 id="depoimentos-title" class="text-2xl font-bold text-gray-900">O que dizem as empresas parceiras</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="flex items-center gap-1 mb-3">
              {[...Array(5)].map((_, i) => <i key={i} class="ri-star-fill text-amber-400 text-sm"></i>)}
            </div>
            <p class="text-gray-600 text-sm italic mb-4">"{t.text}"</p>
            <div>
              <p class="font-semibold text-gray-900 text-sm">{t.name}</p>
              <p class="text-xs text-gray-500">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white" aria-labelledby="faq-empresas-title">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <h2 id="faq-empresas-title" class="text-2xl font-bold text-gray-900">Dúvidas Frequentes</h2>
      </div>
      <FAQAccordion client:visible items={faqItems} />
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-16 bg-emerald-900" aria-label="Chamada para ação empresas">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Pronto para contratar?</h2>
      <p class="text-emerald-200 text-sm mb-8 leading-relaxed">
        Nossa equipe está pronta para criar sua conta e te ajudar a encontrar os melhores profissionais de Santarém.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/interesse-empresa" class="btn-primary bg-white !text-emerald-700 hover:bg-emerald-50">
          <i class="ri-chat-1-line"></i>
          Falar com a equipe
        </a>
        <a href="/como-funciona" class="btn-outline-white">
          <i class="ri-information-line"></i>
          Saber mais
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
