---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JobsFilter from '../../components/islands/JobsFilter';
import { getAllJobs, getUniqueSectors, getUniqueNeighborhoods, getUniqueContractTypes } from '../../lib/jobs';

// SSR — vagas mudam frequentemente, precisamos de dados frescos
export const prerender = false;

const jobs = await getAllJobs();
const sectors = getUniqueSectors(jobs);
const neighborhoods = getUniqueNeighborhoods(jobs);
const contractTypes = getUniqueContractTypes(jobs);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Vagas de Emprego em Santarém PA',
  description: `${jobs.length} vagas disponíveis em Santarém e região`,
  numberOfItems: jobs.length,
  itemListElement: jobs.slice(0, 10).map((job, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://vagasoeste.com.br/vagas/${job.id}`,
    name: `${job.title} em ${job.neighborhood}, ${job.city}`,
  })),
};
---

<BaseLayout
  title={`Vagas em Santarém PA — ${jobs.length}+ Oportunidades | VagasOeste`}
  description={`Todas as vagas de emprego em Santarém/PA por bairro, setor e tipo de contrato. Empresa anônima até sua seleção. ${jobs.length} oportunidades disponíveis.`}
  keywords="vagas Santarém, emprego Santarém PA, vagas CLT Santarém, vagas PJ Pará, oportunidades emprego oeste Pará"
  schema={itemListSchema}
>

  <!-- Hero -->
  <section class="bg-emerald-900 pt-24 pb-12 relative overflow-hidden" aria-label="Listagem de vagas">
    <div class="absolute inset-0">
      <img
        src="https://readdy.ai/api/search-image?query=Santarem%20Para%20Brazil%20city%20center%20downtown%20commercial%20street%20urban%20professional%20environment%20warm%20light&width=1920&height=400&seq=vagas-hero&orientation=landscape"
        alt="Vagas em Santarém Pará"
        class="w-full h-full object-cover opacity-20"
        loading="eager"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-xs text-emerald-300">
          <li><a href="/" class="hover:text-white transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-white font-medium">Vagas</li>
        </ol>
      </nav>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">
        Vagas de Emprego em Santarém/PA
      </h1>
      <p class="text-emerald-200 text-sm">
        <span class="font-semibold text-white">{jobs.length}+</span> vagas disponíveis · Empresa anônima até você ser selecionado
      </p>
    </div>
  </section>

  <!-- Conteúdo com filtros (ilha React) -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <JobsFilter
        client:load
        initialJobs={jobs}
        sectors={sectors}
        neighborhoods={neighborhoods}
        contractTypes={contractTypes}
      />
    </div>
  </section>

  <!-- CTA de cadastro -->
  <section class="py-10 bg-emerald-50 border-t border-emerald-100">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class="text-lg font-bold text-gray-900 mb-2">Não encontrou a vaga ideal?</h2>
      <p class="text-sm text-gray-600 mb-4">
        Cadastre-se gratuitamente e receba alertas quando novas vagas forem publicadas na sua área.
      </p>
      <a href="https://app.vagasoeste.com.br/cadastro" class="btn-primary">
        <i class="ri-user-add-line"></i>
        Criar conta e receber alertas
      </a>
    </div>
  </section>

</BaseLayout>
