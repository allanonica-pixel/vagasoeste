---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllJobs, getJobById, buildJobSchema } from '../../lib/jobs';

// SSR — busca em tempo real para dados sempre frescos
export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect('/vagas');

const job = await getJobById(id);
if (!job) return Astro.redirect('/vagas');

const jobSchema = buildJobSchema(job);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://vagasoeste.com.br/' },
    { '@type': 'ListItem', position: 2, name: 'Vagas', item: 'https://vagasoeste.com.br/vagas' },
    { '@type': 'ListItem', position: 3, name: `${job.title} em ${job.neighborhood}`, item: `https://vagasoeste.com.br/vagas/${job.id}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Quais são os requisitos para esta vaga?', acceptedAnswer: { '@type': 'Answer', text: job.requirements } },
    { '@type': 'Question', name: 'Quais os benefícios oferecidos?', acceptedAnswer: { '@type': 'Answer', text: job.benefits ?? 'Consulte a VagasOeste para detalhes dos benefícios.' } },
    { '@type': 'Question', name: 'Qual o horário de trabalho?', acceptedAnswer: { '@type': 'Answer', text: job.workHours ?? 'Horário a ser informado pela empresa.' } },
    { '@type': 'Question', name: 'Como me candidatar?', acceptedAnswer: { '@type': 'Answer', text: 'Crie uma conta grátis na VagasOeste e candidate-se diretamente pela plataforma.' } },
    { '@type': 'Question', name: 'Quantas vagas estão disponíveis?', acceptedAnswer: { '@type': 'Answer', text: `${job.vacancies ?? 1} vaga(s) disponível(is).` } },
  ],
};

const seoTitle = `${job.title} em ${job.neighborhood}, ${job.city}/PA — ${job.contractType} | VagasOeste`;
const seoDesc = `Vaga de ${job.title} no bairro ${job.neighborhood} em ${job.city}/PA. ${job.contractType}. ${job.salaryRange ? `Salário: ${job.salaryRange}.` : ''} Candidate-se agora na VagasOeste.`;

const contractColorClass = {
  CLT: 'bg-emerald-100 text-emerald-700',
  PJ: 'bg-blue-100 text-blue-700',
  Temporário: 'bg-amber-100 text-amber-700',
  Estágio: 'bg-purple-100 text-purple-700',
  Freelance: 'bg-pink-100 text-pink-700',
}[job.contractType] ?? 'bg-gray-100 text-gray-700';
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  keywords={`${job.title}, vaga ${job.city}, emprego ${job.neighborhood}, ${job.area}, ${job.contractType}, vagas Santarém`}
  schema={[jobSchema, breadcrumbSchema, faqSchema]}
  canonicalURL={`https://vagasoeste.com.br/vagas/${job.id}`}
>

  <!-- Breadcrumb visual -->
  <div class="pt-20 pb-0 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-3">
      <nav aria-label="breadcrumb">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs text-gray-500">
          <li><a href="/" class="hover:text-emerald-600 transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li><a href="/vagas" class="hover:text-emerald-600 transition-colors">Vagas</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-gray-900 font-medium truncate">{job.title}</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Conteúdo -->
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Coluna principal -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Header da Vaga -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <h1 class="text-2xl font-bold text-gray-900 mb-1">{job.title}</h1>
              <p class="text-gray-600 font-medium">{job.area} · {job.sector}</p>
            </div>
            <span class={`shrink-0 inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold ${contractColorClass}`}>
              {job.contractType}
            </span>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div class="flex flex-col gap-0.5">
              <span class="text-xs text-gray-500">Localização</span>
              <span class="text-sm font-medium text-gray-900 flex items-center gap-1">
                <i class="ri-map-pin-line text-emerald-500"></i>
                {job.neighborhood}, {job.city}/PA
              </span>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-xs text-gray-500">Salário</span>
              <span class="text-sm font-medium text-gray-900 flex items-center gap-1">
                <i class="ri-money-dollar-circle-line text-emerald-500"></i>
                {job.salaryRange}
              </span>
            </div>
            {job.workMode && (
              <div class="flex flex-col gap-0.5">
                <span class="text-xs text-gray-500">Modalidade</span>
                <span class="text-sm font-medium text-gray-900 flex items-center gap-1">
                  <i class="ri-computer-line text-emerald-500"></i>
                  {job.workMode}
                </span>
              </div>
            )}
            {job.vacancies && (
              <div class="flex flex-col gap-0.5">
                <span class="text-xs text-gray-500">Vagas</span>
                <span class="text-sm font-medium text-gray-900 flex items-center gap-1">
                  <i class="ri-group-line text-emerald-500"></i>
                  {job.vacancies} vaga{job.vacancies > 1 ? 's' : ''}
                </span>
              </div>
            )}
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-4">
            {job.tags.map((tag) => (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Descrição -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <i class="ri-file-text-line text-emerald-500"></i>
            Descrição da Vaga
          </h2>
          <p class="text-gray-700 leading-relaxed text-sm">{job.description}</p>
        </div>

        <!-- Requisitos -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <i class="ri-checkbox-circle-line text-emerald-500"></i>
            Requisitos
          </h2>
          <p class="text-gray-700 leading-relaxed text-sm">{job.requirements}</p>
        </div>

        <!-- Benefícios -->
        {job.benefits && (
          <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
            <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <i class="ri-gift-line text-emerald-500"></i>
              Benefícios
            </h2>
            <p class="text-gray-700 leading-relaxed text-sm">{job.benefits}</p>
          </div>
        )}

        <!-- FAQ Accordion da Vaga -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 mb-4">Perguntas Frequentes</h2>
          <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
            {[
              { q: 'Quais são os requisitos?', a: job.requirements },
              { q: 'Quais os benefícios?', a: job.benefits ?? 'Consulte a VagasOeste para detalhes.' },
              { q: 'Como me candidatar?', a: 'Crie uma conta grátis na VagasOeste e candidate-se com 1 clique. Seus dados são protegidos.' },
            ].map((item) => (
              <div class="border border-gray-200 rounded-lg p-4" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                <h3 class="font-semibold text-gray-900 text-sm mb-2" itemprop="name">{item.q}</h3>
                <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                  <p class="text-sm text-gray-600" itemprop="text">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar de Candidatura -->
      <aside class="lg:col-span-1">
        <div class="sticky top-20 space-y-4">

          <!-- Card de candidatura -->
          <div class="bg-white rounded-xl border border-emerald-200 shadow-sm p-6">
            <div class="text-center mb-5">
              <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <i class="ri-briefcase-line text-2xl text-emerald-600"></i>
              </div>
              <h2 class="font-bold text-gray-900 mb-1">Interessado nesta vaga?</h2>
              <p class="text-xs text-gray-500">Processo 100% anônimo e seguro</p>
            </div>

            <div class="space-y-2 mb-5">
              <a
                href={`https://app.vagasoeste.com.br/cadastro?jobId=${job.id}`}
                class="btn-primary w-full justify-center"
              >
                <i class="ri-user-add-line"></i>
                Criar conta e candidatar
              </a>
              <a
                href={`https://app.vagasoeste.com.br/login?redirect=/plataforma&jobId=${job.id}`}
                class="btn-secondary w-full justify-center"
              >
                <i class="ri-login-box-line"></i>
                Já tenho conta
              </a>
            </div>

            <div class="bg-emerald-50 rounded-lg p-3">
              <p class="text-xs font-semibold text-emerald-800 mb-2 flex items-center gap-1">
                <i class="ri-shield-check-line"></i>
                Processo seguro VagasOeste
              </p>
              <ul class="space-y-1.5">
                {[
                  'Empresa fica anônima até você ser selecionado',
                  'Seus dados pessoais são protegidos',
                  'Acompanhamento por WhatsApp e email',
                  'Intermediado pela nossa equipe',
                ].map((item) => (
                  <li class="flex items-start gap-1.5 text-xs text-emerald-700">
                    <i class="ri-check-line shrink-0 mt-0.5"></i>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Card de resumo -->
          <div class="bg-gray-50 rounded-xl border border-gray-100 p-5">
            <h3 class="font-semibold text-gray-900 text-sm mb-3">Resumo da Vaga</h3>
            <dl class="space-y-2">
              {[
                { label: 'Setor', value: job.sector },
                { label: 'Contrato', value: job.contractType },
                { label: 'Bairro', value: `${job.neighborhood}, ${job.city}` },
                { label: 'Salário', value: job.salaryRange },
                { label: 'Publicado em', value: new Date(job.createdAt).toLocaleDateString('pt-BR') },
              ].map(({ label, value }) => (
                <div class="flex justify-between gap-2">
                  <dt class="text-xs text-gray-500">{label}</dt>
                  <dd class="text-xs font-medium text-gray-900 text-right">{value}</dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Link para todas as vagas -->
          <a href="/vagas" class="flex items-center justify-center gap-2 text-sm text-emerald-600 hover:text-emerald-700 font-medium py-2 transition-colors">
            <i class="ri-arrow-left-line"></i>
            Ver todas as vagas
          </a>
        </div>
      </aside>
    </div>
  </div>

</BaseLayout>
