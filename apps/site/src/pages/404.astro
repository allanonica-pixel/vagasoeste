---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout
  title="Página não encontrada — VagasOeste"
  description="A página que você procura não existe. Explore as vagas de emprego disponíveis em Santarém/PA."
>
  <div class="min-h-dvh flex items-center justify-center px-4 pt-16">
    <div class="text-center max-w-md">
      <div class="size-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <i class="ri-emotion-sad-line text-4xl text-emerald-400" aria-hidden="true"></i>
      </div>
      <h1 class="text-6xl font-bold text-gray-200 mb-2">404</h1>
      <h2 class="text-xl font-bold text-gray-900 mb-3 text-balance">Página não encontrada</h2>
      <p class="text-sm text-gray-600 mb-8 leading-relaxed text-pretty">
        A página que você procura pode ter sido movida ou não existe mais.
        Mas temos centenas de vagas esperando por você!
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-secondary">
          <i class="ri-home-line" aria-hidden="true"></i>
          Ir para a home
        </a>
        <a href="/vagas" class="btn-primary">
          <i class="ri-briefcase-line" aria-hidden="true"></i>
          Ver vagas disponíveis
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
