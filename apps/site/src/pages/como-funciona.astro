---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/islands/FAQAccordion';

export const prerender = true;

const steps = [
  {
    icon: 'ri-user-add-line',
    title: 'Crie sua conta gratuitamente',
    desc: 'Cadastro em 4 etapas simples: dados pessoais, perfil profissional, cursos e criação de senha. Processo rápido e sem custo.',
    side: 'left',
  },
  {
    icon: 'ri-search-eye-line',
    title: 'Explore as vagas disponíveis',
    desc: 'Navegue pelas vagas por bairro, setor e tipo de contrato. A empresa anunciante é anônima — você vê apenas a função e a localização.',
    side: 'right',
  },
  {
    icon: 'ri-send-plane-line',
    title: 'Candidate-se com 1 clique',
    desc: 'Sem precisar enviar email, ligar ou se expor. Sua candidatura é enviada de forma segura e anônima para análise.',
    side: 'left',
  },
  {
    icon: 'ri-team-line',
    title: 'Nossa equipe intermedia',
    desc: 'A VagasOeste analisa seu perfil junto à empresa. Todo o contato é feito pela nossa equipe, garantindo privacidade dos dois lados.',
    side: 'right',
  },
  {
    icon: 'ri-notification-3-line',
    title: 'Acompanhe por WhatsApp e email',
    desc: 'Receba notificações em tempo real sobre cada etapa do processo: análise, pré-entrevista, entrevista e resultado.',
    side: 'left',
  },
  {
    icon: 'ri-trophy-line',
    title: 'Conquiste a vaga',
    desc: 'Quando aprovado, a VagasOeste revela a empresa e coordena a formalização. Você é acompanhado até a contratação.',
    side: 'right',
  },
];

const benefits = [
  { icon: 'ri-shield-check-line', title: 'Processo 100% anônimo', desc: 'Empresa não sabe quem você é. Você não sabe qual empresa é. Só quando selecionado.' },
  { icon: 'ri-lock-line', title: 'Dados protegidos', desc: 'Seu nome, telefone e email nunca são compartilhados com as empresas.' },
  { icon: 'ri-heart-line', title: 'Gratuito para candidatos', desc: 'Cadastro, candidatura e currículo PDF são totalmente gratuitos para você.' },
  { icon: 'ri-map-pin-line', title: 'Vagas locais reais', desc: 'Todas as vagas são de empresas parceiras verificadas em Santarém e região.' },
  { icon: 'ri-file-user-line', title: 'Currículo profissional', desc: 'Crie um currículo dentro da plataforma e baixe em PDF de graça.' },
  { icon: 'ri-customer-service-2-line', title: 'Suporte humanizado', desc: 'Nossa equipe está disponível para tirar dúvidas e acompanhar seu processo.' },
];

const faqItems = [
  { question: 'É realmente gratuito para candidatos?', answer: 'Sim! Cadastro, candidatura e download de currículo em PDF são 100% gratuitos para candidatos. Nunca cobraremos pelo acesso básico à plataforma.' },
  { question: 'Por que a empresa fica anônima?', answer: 'Para proteger ambos os lados. Candidatos evitam constrangimentos com ex-empregadores ou conhecidos. Empresas recebem candidaturas baseadas em competências, não em relações pessoais.' },
  { question: 'Meus dados ficam seguros?', answer: 'Sim. Seu nome, email, telefone e WhatsApp nunca são compartilhados com as empresas. Elas veem apenas seu perfil profissional: bairro, formação, experiência e pretensão salarial.' },
  { question: 'Posso me candidatar a várias vagas ao mesmo tempo?', answer: 'Sim! Você pode se candidatar a quantas vagas quiser simultaneamente. Cada candidatura é tratada de forma independente.' },
  { question: 'Como funciona a notificação por WhatsApp?', answer: 'Após o cadastro, você pode ativar notificações por WhatsApp nas preferências da plataforma. Você receberá mensagens em cada etapa do processo seletivo.' },
  { question: 'O que acontece quando sou selecionado?', answer: 'A VagasOeste entra em contato com você diretamente, informa o nome da empresa e coordena a próxima etapa — seja uma entrevista presencial, online ou contratação direta.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="Como Funciona — VagasOeste Santarém"
  description="Entenda como funciona a VagasOeste: processo de candidatura anônimo e seguro para candidatos em Santarém/PA. Do cadastro à contratação em 6 etapas simples."
  keywords="como funciona VagasOeste, processo seletivo Santarém, candidatura anônima emprego, plataforma emprego Pará"
  schema={faqSchema}
>

  <!-- Hero -->
  <section class="relative pt-24 pb-16 overflow-hidden" aria-label="Como Funciona">
    <div class="absolute inset-0">
      <img
        src="https://readdy.ai/api/search-image?query=professional%20team%20meeting%20office%20collaboration%20Santarem%20Para%20Brazil%20warm%20light%20modern%20workspace%20people%20working%20together&width=1920&height=500&seq=como-funciona-hero&orientation=landscape"
        alt="Como funciona a VagasOeste"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-emerald-950/75"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6 text-center">
      <nav aria-label="breadcrumb" class="mb-6 flex justify-center">
        <ol class="flex items-center gap-1.5 text-xs text-emerald-300">
          <li><a href="/" class="hover:text-white transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-white font-medium">Como Funciona</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Do cadastro à contratação,<br class="hidden md:block" />
        <span class="text-emerald-300">com segurança e anonimato</span>
      </h1>
      <p class="text-white/80 text-sm md:text-base max-w-xl mx-auto leading-relaxed mb-8">
        A VagasOeste protege candidatos e empresas durante todo o processo seletivo em Santarém e região.
      </p>
      <a href="https://app.vagasoeste.com.br/cadastro" class="btn-primary">
        <i class="ri-user-add-line"></i>
        Criar conta grátis
      </a>
    </div>
  </section>

  <!-- Timeline de etapas -->
  <section class="py-16 bg-white" aria-labelledby="etapas-title">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Passo a passo</p>
        <h2 id="etapas-title" class="text-2xl font-bold text-gray-900">6 Etapas Simples</h2>
      </div>

      <div class="relative">
        <!-- Linha vertical (desktop) -->
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-emerald-100 -translate-x-1/2"></div>

        <div class="space-y-8 md:space-y-0">
          {steps.map((step, i) => (
            <div class={`flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10 ${step.side === 'right' ? 'md:flex-row-reverse' : ''} md:mb-12`}>
              <!-- Conteúdo -->
              <div class={`flex-1 ${step.side === 'right' ? 'md:text-right' : ''}`}>
                <div class={`bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow`}>
                  <p class="text-xs font-bold text-emerald-600 mb-1">Etapa {i + 1}</p>
                  <h3 class="font-bold text-gray-900 text-base mb-2">{step.title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed">{step.desc}</p>
                </div>
              </div>

              <!-- Ícone central -->
              <div class="hidden md:flex w-12 h-12 rounded-full bg-emerald-600 border-4 border-white shadow-md items-center justify-center shrink-0 z-10">
                <i class={`${step.icon} text-white text-xl`}></i>
              </div>

              <!-- Espaço vazio para alternância -->
              <div class="hidden md:block flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Benefícios -->
  <section class="py-16 bg-gray-50" aria-labelledby="beneficios-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Por que VagasOeste?</p>
        <h2 id="beneficios-title" class="text-2xl font-bold text-gray-900">Nossos Diferenciais</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((b) => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <i class={`${b.icon} text-emerald-600 text-xl`}></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{b.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white" aria-labelledby="faq-title">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Dúvidas comuns</p>
        <h2 id="faq-title" class="text-2xl font-bold text-gray-900">Perguntas Frequentes</h2>
      </div>
      <FAQAccordion client:visible items={faqItems} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-emerald-900" aria-label="Chamada para ação">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Pronto para começar?</h2>
      <p class="text-emerald-200 text-sm mb-8 leading-relaxed">
        Crie sua conta gratuitamente e encontre oportunidades em Santarém com segurança.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/vagas" class="btn-outline-white">
          <i class="ri-briefcase-line"></i>
          Ver vagas disponíveis
        </a>
        <a href="https://app.vagasoeste.com.br/cadastro" class="btn-primary bg-white !text-emerald-700 hover:bg-emerald-50">
          <i class="ri-user-add-line"></i>
          Criar conta grátis
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
