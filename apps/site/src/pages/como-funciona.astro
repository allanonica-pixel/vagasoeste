---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/islands/FAQAccordion';
// ↓ Fonte única da verdade — altere em packages/content/src/como-funciona.ts
import { steps, benefits, faqItems } from '@content/como-funciona';

export const prerender = true;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="Como Funciona — VagasOeste Santarém"
  description="Entenda como funciona a VagasOeste: processo de candidatura anônimo e seguro para candidatos em Santarém/PA. Do cadastro à contratação em 6 etapas simples."
  keywords="como funciona VagasOeste, processo seletivo Santarém, candidatura anônima emprego, plataforma emprego Pará"
  schema={faqSchema}
>

  <!-- Hero -->
  <section class="relative pt-24 pb-16 overflow-hidden" aria-label="Como Funciona">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-900 via-emerald-950 to-gray-900">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_40%_50%,rgba(16,185,129,0.15),transparent_65%)]"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6 text-center">
      <nav aria-label="breadcrumb" class="mb-6 flex justify-center">
        <ol class="flex items-center gap-1.5 text-xs text-emerald-300">
          <li><a href="/" class="hover:text-white transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-white font-medium">Como Funciona</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Do cadastro à contratação,<br class="hidden md:block" />
        <span class="text-emerald-300">com controle total em cada etapa</span>
      </h1>
      <p class="text-white/80 text-sm md:text-base max-w-xl mx-auto leading-relaxed mb-8">
        A VagasOeste conecta candidatos e empresas com um processo automatizado, seguro e com anonimato durante a seleção.
      </p>
      <button type="button" onclick="window.dispatchEvent(new CustomEvent('openRegisterModal'))" class="btn-primary">
        <i class="ri-user-add-line"></i>
        Criar conta grátis
      </button>
    </div>
  </section>

  <!-- Timeline de etapas -->
  <section class="py-16 bg-white" aria-labelledby="etapas-title">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Passo a passo</p>
        <h2 id="etapas-title" class="text-2xl font-bold text-gray-900">6 Etapas Simples</h2>
      </div>

      <div class="relative">
        <!-- Linha vertical (desktop) -->
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-emerald-100 -translate-x-1/2"></div>

        <div class="space-y-8 md:space-y-0">
          {steps.map((step, i) => (
            <div class={`flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10 ${step.side === 'right' ? 'md:flex-row-reverse' : ''} md:mb-12`}>
              <!-- Conteúdo -->
              <div class={`flex-1 ${step.side === 'right' ? 'md:text-right' : ''}`}>
                <div class={`bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow`}>
                  <p class="text-xs font-bold text-emerald-600 mb-1">Etapa {i + 1}</p>
                  <h3 class="font-bold text-gray-900 text-base mb-2">{step.title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed">{step.desc}</p>
                </div>
              </div>

              <!-- Ícone central -->
              <div class="hidden md:flex w-12 h-12 rounded-full bg-emerald-600 border-4 border-white shadow-md items-center justify-center shrink-0 z-10">
                <i class={`${step.icon} text-white text-xl`}></i>
              </div>

              <!-- Espaço vazio para alternância -->
              <div class="hidden md:block flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Benefícios -->
  <section class="py-16 bg-gray-50" aria-labelledby="beneficios-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Por que escolher a VagasOeste?</p>
        <h2 id="beneficios-title" class="text-2xl font-bold text-gray-900">Diferenciais que tornam seu processo mais seguro, eficiente e profissional</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((b) => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
              <i class={`${b.icon} text-emerald-600 text-xl`}></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{b.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white" aria-labelledby="faq-title">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">Dúvidas comuns</p>
        <h2 id="faq-title" class="text-2xl font-bold text-gray-900">Perguntas Frequentes</h2>
      </div>
      <FAQAccordion client:visible items={faqItems} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-emerald-900" aria-label="Chamada para ação">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Pronto para começar?</h2>
      <p class="text-emerald-200 text-sm mb-8 leading-relaxed">
        Crie sua conta gratuitamente e encontre oportunidades em Santarém com segurança.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/vagas" class="btn-outline-white">
          <i class="ri-briefcase-line"></i>
          Ver vagas disponíveis
        </a>
        <button type="button" onclick="window.dispatchEvent(new CustomEvent('openRegisterModal'))" class="btn-primary bg-white !text-emerald-700 hover:bg-emerald-50">
          <i class="ri-user-add-line"></i>
          Criar conta grátis
        </button>
      </div>
    </div>
  </section>

</BaseLayout>
