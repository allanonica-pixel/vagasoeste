<!-- ═══════════════════════════════════════════════════════════════════════════
     JavaScript — abas, máscaras, validações e fluxo OTP
═══════════════════════════════════════════════════════════════════════════════ -->
<script define:vars={{ apiUrl, appUrl }}>

// ── Utilitários de máscara ─────────────────────────────────────────────────
function maskCNPJ(v) {
  v = v.replace(/\D/g, '').substring(0, 14);
  if (v.length > 12) return v.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{0,2})/, '$1.$2.$3/$4-$5');
  if (v.length > 8)  return v.replace(/^(\d{2})(\d{3})(\d{3})(\d{0,4})/,        '$1.$2.$3/$4');
  if (v.length > 5)  return v.replace(/^(\d{2})(\d{3})(\d{0,3})/,               '$1.$2.$3');
  if (v.length > 2)  return v.replace(/^(\d{2})(\d{0,3})/,                      '$1.$2');
  return v;
}

function maskPhone(v) {
  v = v.replace(/\D/g, '').substring(0, 11);
  if (v.length > 10) return v.replace(/^(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
  if (v.length > 6)  return v.replace(/^(\d{2})(\d{4,5})(\d{0,4})/, '($1) $2-$3');
  if (v.length > 2)  return v.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
  if (v.length > 0)  return '(' + v;
  return v;
}

// ── Validadores ────────────────────────────────────────────────────────────
function validarCNPJ(cnpj) {
  const n = cnpj.replace(/\D/g, '');
  if (n.length !== 14 || /^(\d)\1{13}$/.test(n)) return false;
  const calc = (s, w) => s.split('').reduce((a, d, i) => a + +d * w[i], 0);
  const w1 = [5,4,3,2,9,8,7,6,5,4,3,2];
  const w2 = [6,5,4,3,2,9,8,7,6,5,4,3,2];
  const d1 = 11 - (calc(n.slice(0,12), w1) % 11);
  const d2 = 11 - (calc(n.slice(0,13), w2) % 11);
  return +n[12] === (d1>=10?0:d1) && +n[13] === (d2>=10?0:d2);
}

function validarEmail(v) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v);
}

function validarPhone(v) {
  const d = v.replace(/\D/g, '');
  return d.length >= 10 && d.length <= 11;
}

// ── Feedback visual em campos ──────────────────────────────────────────────
function setField(input, valid, msgEl, msg) {
  input.classList.remove('border-emerald-400', 'border-red-400');
  if (valid === true)  input.classList.add('border-emerald-400');
  if (valid === false) input.classList.add('border-red-400');
  if (msgEl) {
    msgEl.textContent = msg ?? '';
    msgEl.className = `text-xs mt-1 ${valid === false ? 'text-red-500' : 'text-gray-400'}`;
    msgEl.classList.toggle('hidden', !msg);
  }
}

// ── Helper: seta valor num campo ──────────────────────────────────────────
function setVal(id, val) {
  const el = document.getElementById(id);
  if (el && val != null && val !== undefined) el.value = String(val);
}

// ── Máscara CEP ────────────────────────────────────────────────────────────
function maskCEP(v) {
  v = v.replace(/\D/g, '').substring(0, 8);
  if (v.length > 5) return v.replace(/^(\d{5})(\d{0,3})/, '$1-$2');
  return v;
}

// ── ViaCEP lookup ──────────────────────────────────────────────────────────
async function lookupCEP(digits) {
  if (digits.length !== 8) return;
  const spinner = document.getElementById('cep-spinner');
  spinner?.classList.remove('hidden');
  try {
    const res  = await fetch(`https://viacep.com.br/ws/${digits}/json/`);
    const data = await res.json();
    if (data.erro) throw new Error('CEP não encontrado.');
    setVal('logradouro',     data.logradouro ?? '');
    setVal('bairro_empresa', data.bairro     ?? '');
    const nb = document.getElementById('neighborhood');
    if (nb && !nb.value && data.bairro) nb.value = data.bairro;
  } catch { /* silencia */ }
  finally { spinner?.classList.add('hidden'); }
}

// ── Estado CNPJ já cadastrado ──────────────────────────────────────────────
let _cnpjBloqueado      = false;
let _lastLookedUpCNPJ   = '';   // evita chamadas duplicadas (input + blur)

function showCnpjExistsBanner(status) {
  const banner  = document.getElementById('cnpj-exists-banner');
  const title   = document.getElementById('cnpj-exists-title');
  const msg     = document.getElementById('cnpj-exists-msg');
  const link    = document.getElementById('cnpj-exists-link');
  const linkTxt = document.getElementById('cnpj-exists-link-text');

  if (status === 'ativo') {
    title.textContent   = 'CNPJ já possui Cadastro';
    msg.textContent     = 'Este CNPJ já possui uma conta ativa na plataforma. Acesse a plataforma para gerenciar suas vagas.';
    link.href           = `${appUrl}/acesso-restrito`;
    linkTxt.textContent = 'Acessar a plataforma →';
  } else if (status === 'pendente') {
    title.textContent   = 'Pré-cadastro já em análise';
    msg.textContent     = 'Este CNPJ já possui um pré-cadastro pendente. Nossa equipe entrará em contato pelo WhatsApp ou e-mail em breve.';
    link.href           = 'mailto:empresas@santarem.app';
    linkTxt.textContent = 'Entrar em contato por e-mail →';
  }

  _cnpjBloqueado = true;
  banner.classList.remove('hidden');
}

function hideCnpjExistsBanner() {
  document.getElementById('cnpj-exists-banner').classList.add('hidden');
  _cnpjBloqueado = false;
}

// ── Limpa os indicadores visuais do campo CNPJ ────────────────────────────
function resetCnpjIndicators() {
  document.getElementById('cnpj-spinner').classList.add('hidden');
  document.getElementById('cnpj-ok').classList.add('hidden');
  document.getElementById('cnpj-err').classList.add('hidden');
  const msgEl = document.getElementById('cnpj-msg');
  msgEl.classList.add('hidden');
  msgEl.textContent = '';
}

// ── Lookup CNPJ: plataforma primeiro → Receita Federal depois ─────────────
async function lookupCNPJ(digits) {
  const spinner = document.getElementById('cnpj-spinner');
  const okIcon  = document.getElementById('cnpj-ok');
  const errIcon = document.getElementById('cnpj-err');
  const msgEl   = document.getElementById('cnpj-msg');

  // Mostra spinner, oculta ícones anteriores
  spinner.classList.remove('hidden');
  okIcon.classList.add('hidden');
  errIcon.classList.add('hidden');
  msgEl.classList.add('hidden');
  hideCnpjExistsBanner();

  try {
    // ── ETAPA 1: verifica na nossa base de dados ───────────────────────────
    const checkRes  = await fetch(`${apiUrl}/v1/interesse/check-cnpj?cnpj=${digits}`);
    const checkData = await checkRes.json();

    if (checkData.status) {
      // CNPJ já cadastrado → bloqueia e exibe banner imediatamente
      spinner.classList.add('hidden');
      errIcon.classList.remove('hidden');
      msgEl.textContent = checkData.status === 'ativo'
        ? 'CNPJ já possui Cadastro na plataforma.'
        : 'Pré-cadastro já em análise para este CNPJ.';
      msgEl.className = 'text-xs mt-1 text-amber-600';
      msgEl.classList.remove('hidden');
      showCnpjExistsBanner(checkData.status);
      return; // não consulta Receita Federal
    }

    // ── ETAPA 2: CNPJ livre → busca dados na Receita Federal (BrasilAPI) ──
    const res = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${digits}`);
    if (!res.ok) throw new Error('CNPJ não encontrado na Receita Federal.');
    const data = await res.json();

    setVal('razao_social',   data.razao_social ?? '');
    // Bug F: nome fantasia só auto-popula se Receita devolver explicitamente.
    // Sem fallback pra razão social — força usuário a digitar conscientemente
    // como o público conhece a empresa.
    setVal('company_name',   data.nome_fantasia ?? '');

    // Limpa erro da Razão Social se estava marcado
    const rsEl    = document.getElementById('razao_social');
    const rsMsgEl = document.getElementById('razao-social-msg');
    rsEl?.classList.remove('border-red-400');
    rsMsgEl?.classList.add('hidden');
    setVal('logradouro',     data.logradouro ?? '');
    setVal('numero',         data.numero      ?? '');
    setVal('bairro_empresa', data.bairro      ?? '');

    const cepRaw = (data.cep ?? '').replace(/\D/g, '');
    setVal('cep', maskCEP(cepRaw));

    // Bairro de OPERAÇÃO (não fiscal) NÃO é auto-preenchido pela BrasilAPI.
    // Usuário deve selecionar/digitar baseado nos bairros cadastrados na cidade
    // de operação (após selecionar Estado e Cidade nos dropdowns).

    spinner.classList.add('hidden');
    okIcon.classList.remove('hidden');
    msgEl.textContent = 'Dados preenchidos automaticamente.';
    msgEl.className = 'text-xs mt-1 text-emerald-600';
    msgEl.classList.remove('hidden');
  } catch (e) {
    spinner.classList.add('hidden');
    errIcon.classList.remove('hidden');
    msgEl.textContent = e.message ?? 'CNPJ não encontrado.';
    msgEl.className = 'text-xs mt-1 text-red-500';
    msgEl.classList.remove('hidden');
  }
}

// ── Estado da sessão OTP ───────────────────────────────────────────────────
let _sessionId = null;
let _phone     = null;

function clearSession() {
  if (_sessionId) {
    fetch(`${apiUrl}/v1/interesse/invalidate-session`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sessionId: _sessionId }),
    }).catch(() => {});
  }
  _sessionId = null;
}

// ── Coleta dados do formulário ─────────────────────────────────────────────
function coletarDados() {
  const g = (id) => (document.getElementById(id)?.value ?? '').trim();
  const setores = [...document.querySelectorAll('.setor-check:checked')].map(el => el.value);
  const vagasEl = document.querySelector('input[name="vacancies_qty"]:checked');
  return {
    cnpj:              g('cnpj'),
    razao_social:      g('razao_social'),
    company_name:      g('company_name'),
    setores,
    estado_uf:         g('estado_uf'),
    cidade:            g('cidade'),
    cidade_id:         g('cidade_id') || undefined,
    neighborhood:      g('neighborhood'),
    cep:               g('cep').replace(/\D/g, ''),
    logradouro:        g('logradouro'),
    numero:            g('numero'),
    bairro_empresa:    g('bairro_empresa'),
    contact_name:      g('contact_name').toUpperCase(),
    contact_role:      g('contact_role').toUpperCase(),
    contact_email:     g('contact_email'),
    contact_whatsapp:  g('contact_whatsapp'),
    contact_password:  g('contact_password'),
    vacancies_qty:     vagasEl?.value ?? '',
    message:           g('message'),
  };
}

// ── Validação aba 1 (Dados da Empresa) ────────────────────────────────────
function validarAba1() {
  let ok = true;

  // ── CNPJ: obrigatório, 14 dígitos, válido, sem bloqueio ──────────────
  const cnpjEl      = document.getElementById('cnpj');
  const cnpjErrIcon = document.getElementById('cnpj-err');
  const cnpjOkIcon  = document.getElementById('cnpj-ok');
  const cnpjMsgEl   = document.getElementById('cnpj-msg');
  const digits      = (cnpjEl?.value ?? '').replace(/\D/g, '');

  if (!digits) {
    cnpjEl?.classList.add('border-red-400');
    cnpjEl?.classList.remove('border-emerald-400');
    cnpjOkIcon?.classList.add('hidden');
    cnpjErrIcon?.classList.remove('hidden');
    cnpjMsgEl.textContent = 'O CNPJ é obrigatório.';
    cnpjMsgEl.className   = 'text-xs mt-1 text-red-500';
    cnpjMsgEl.classList.remove('hidden');
    ok = false;
  } else if (digits.length < 14) {
    cnpjEl?.classList.add('border-red-400');
    cnpjEl?.classList.remove('border-emerald-400');
    cnpjOkIcon?.classList.add('hidden');
    cnpjErrIcon?.classList.remove('hidden');
    cnpjMsgEl.textContent = 'CNPJ incompleto — informe os 14 dígitos.';
    cnpjMsgEl.className   = 'text-xs mt-1 text-red-500';
    cnpjMsgEl.classList.remove('hidden');
    ok = false;
  } else if (!validarCNPJ(digits)) {
    cnpjEl?.classList.add('border-red-400');
    cnpjEl?.classList.remove('border-emerald-400');
    cnpjOkIcon?.classList.add('hidden');
    cnpjErrIcon?.classList.remove('hidden');
    cnpjMsgEl.textContent = 'CNPJ inválido. Verifique e tente novamente.';
    cnpjMsgEl.className   = 'text-xs mt-1 text-red-500';
    cnpjMsgEl.classList.remove('hidden');
    ok = false;
  } else if (_cnpjBloqueado) {
    // Banner de bloqueio já está visível — só impede avançar
    ok = false;
  }

  // ── Razão Social: obrigatória (auto-preenchida pelo lookup do CNPJ) ──
  const rsEl    = document.getElementById('razao_social');
  const rsMsgEl = document.getElementById('razao-social-msg');
  if (!rsEl?.value.trim()) {
    rsEl?.classList.add('border-red-400');
    rsMsgEl.textContent = (digits.length === 14 && validarCNPJ(digits) && !_cnpjBloqueado)
      ? 'Razão Social não encontrada. Verifique o CNPJ ou sua conexão e aguarde a busca automática.'
      : 'Digite um CNPJ válido acima para preencher a Razão Social automaticamente.';
    rsMsgEl.className = 'text-xs mt-1 text-red-500';
    rsMsgEl.classList.remove('hidden');
    ok = false;
  } else {
    rsEl?.classList.remove('border-red-400');
    rsMsgEl.classList.add('hidden');
  }

  // ── Nome Fantasia ────────────────────────────────────────────────────
  const nameEl = document.getElementById('company_name');
  if (!nameEl?.value.trim()) { setField(nameEl, false); ok = false; }
  else setField(nameEl, true);

  // ── Estado da operação ───────────────────────────────────────────────
  const estadoEl = document.getElementById('estado_uf');
  if (!estadoEl?.value) { setField(estadoEl, false); ok = false; }
  else setField(estadoEl, true);

  // ── Cidade da operação ───────────────────────────────────────────────
  const cidadeEl = document.getElementById('cidade');
  if (!cidadeEl?.value) { setField(cidadeEl, false); ok = false; }
  else setField(cidadeEl, true);

  // ── Bairro ───────────────────────────────────────────────────────────
  const nbEl = document.getElementById('neighborhood');
  if (!nbEl?.value.trim()) { setField(nbEl, false); ok = false; }
  else setField(nbEl, true);

  // ── Setores ──────────────────────────────────────────────────────────
  const setoresMsg = document.getElementById('setores-msg');
  const setores    = [...document.querySelectorAll('.setor-check:checked')];
  if (setores.length === 0) { setoresMsg.classList.remove('hidden'); ok = false; }
  else setoresMsg.classList.add('hidden');

  return ok;
}

// ── Validação aba 2 (Responsável + Informações) ───────────────────────────
function validarAba2() {
  let ok = true;

  const cnEl = document.getElementById('contact_name');
  if (!cnEl?.value.trim()) { setField(cnEl, false); ok = false; }
  else setField(cnEl, true);

  const crEl = document.getElementById('contact_role');
  if (!crEl?.value.trim()) { setField(crEl, false); ok = false; }
  else setField(crEl, true);

  const emailEl  = document.getElementById('contact_email');
  const emailMsg = document.getElementById('email-msg');
  if (!emailEl?.value || !validarEmail(emailEl.value)) {
    setField(emailEl, false, emailMsg, 'E-mail inválido.');
    ok = false;
  } else setField(emailEl, true, emailMsg, '');

  const waEl  = document.getElementById('contact_whatsapp');
  const waMsg = document.getElementById('whatsapp-msg');
  if (!waEl?.value || !validarPhone(waEl.value)) {
    setField(waEl, false, waMsg, 'Número inválido. Use (93) 9 9999-9999.');
    ok = false;
  } else setField(waEl, true, waMsg, '');

  // Senha
  const senhaEl    = document.getElementById('contact_password');
  const senhaMsg   = document.getElementById('senha-msg');
  const confirmEl  = document.getElementById('contact_password_confirm');
  const confirmMsg = document.getElementById('senha-confirm-msg');
  const senhaVal   = senhaEl?.value ?? '';
  const confirmVal = confirmEl?.value ?? '';

  if (senhaVal.length < 8) {
    setField(senhaEl, false, senhaMsg, 'A senha deve ter no mínimo 8 caracteres.');
    ok = false;
  } else {
    setField(senhaEl, true, senhaMsg, '');
  }

  if (!confirmVal) {
    setField(confirmEl, false, confirmMsg, 'Confirme a senha.');
    ok = false;
  } else if (confirmVal !== senhaVal) {
    setField(confirmEl, false, confirmMsg, 'As senhas não coincidem.');
    ok = false;
  } else {
    setField(confirmEl, true, confirmMsg, '');
  }

  // Vagas
  const vagasMsg = document.getElementById('vagas-msg');
  const vagasEl  = document.querySelector('input[name="vacancies_qty"]:checked');
  if (!vagasEl) { vagasMsg.classList.remove('hidden'); ok = false; }
  else vagasMsg.classList.add('hidden');

  return ok;
}

// ── Lógica das abas ────────────────────────────────────────────────────────
function ativarAba(aba) {
  // aba: 'empresa' | 'responsavel'
  const panelEmpresa     = document.getElementById('panel-empresa');
  const panelResponsavel = document.getElementById('panel-responsavel');
  const tabEmpresa       = document.getElementById('tab-empresa');
  const tabResponsavel   = document.getElementById('tab-responsavel');

  const isEmpresa = aba === 'empresa';

  panelEmpresa.classList.toggle('hidden', !isEmpresa);
  panelResponsavel.classList.toggle('hidden', isEmpresa);

  // Estilo da aba ativa
  tabEmpresa.setAttribute('aria-selected', isEmpresa ? 'true' : 'false');
  tabResponsavel.setAttribute('aria-selected', isEmpresa ? 'false' : 'true');

  if (isEmpresa) {
    tabEmpresa.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
    tabEmpresa.classList.remove('text-gray-500', 'hover:text-gray-700');
    tabResponsavel.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
    tabResponsavel.classList.add('text-gray-500', 'hover:text-gray-700');
  } else {
    tabResponsavel.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
    tabResponsavel.classList.remove('text-gray-500', 'hover:text-gray-700');
    tabEmpresa.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
    tabEmpresa.classList.add('text-gray-500', 'hover:text-gray-700');
    // Rola para o topo do formulário
    document.getElementById('form-wrapper')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

// ── Exibe/oculta modais ────────────────────────────────────────────────────
function showModal(id) {
  document.getElementById(id).classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function hideModal(id) {
  document.getElementById(id).classList.add('hidden');
}
function hideAllModals() {
  ['modal-otp', 'modal-resumo', 'modal-sucesso'].forEach(hideModal);
  document.body.style.overflow = '';
}

// ── Preenche o resumo ──────────────────────────────────────────────────────
function preencherResumo(dados) {
  const container = document.getElementById('resumo-conteudo');
  const linha = (label, valor) => valor
    ? `<div class="flex justify-between gap-4 text-sm border-b border-gray-50 pb-2">
         <span class="text-gray-500 shrink-0">${label}</span>
         <span class="font-medium text-gray-900 text-right">${valor}</span>
       </div>`
    : '';

  container.innerHTML = [
    linha('Empresa',       dados.company_name),
    linha('Razão Social',  dados.razao_social),
    linha('CNPJ',          dados.cnpj),
    linha('Setor(es)',     dados.setores.join(', ')),
    linha('Estado',        dados.estado_uf),
    linha('Cidade',        dados.cidade),
    linha('Bairro',        dados.neighborhood),
    linha('Logradouro',    dados.logradouro ? `${dados.logradouro}, ${dados.numero || 'S/N'}` : ''),
    linha('Bairro fiscal', dados.bairro_empresa),
    linha('CEP',           dados.cep),
    linha('Responsável',   dados.contact_name),
    linha('Cargo',         dados.contact_role),
    linha('Email',         dados.contact_email),
    linha('WhatsApp',      dados.contact_whatsapp),
    linha('Vagas',         dados.vacancies_qty),
    linha('Mensagem',      dados.message),
    // Senha não exibida no resumo por segurança
  ].join('');
}

// ── Timer de reenvio (60s) ─────────────────────────────────────────────────
let _timerInterval = null;
function iniciarTimer() {
  const btn   = document.getElementById('btn-reenviar');
  const timer = document.getElementById('otp-reenviar-timer');
  btn.disabled = true;
  let seg = 60;
  const tick = () => {
    timer.textContent = `Reenviar disponível em ${seg}s`;
    if (seg <= 0) {
      clearInterval(_timerInterval);
      btn.disabled = false;
      timer.textContent = '';
    }
    seg--;
  };
  tick();
  _timerInterval = setInterval(tick, 1000);
}

// ── Toggle visibilidade de senha ──────────────────────────────────────────
function setupPasswordToggle(btnId, inputId, iconId) {
  const btn   = document.getElementById(btnId);
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  if (!btn || !input || !icon) return;

  btn.addEventListener('click', () => {
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    icon.className = isPassword ? 'ri-eye-off-line text-base' : 'ri-eye-line text-base';
    btn.setAttribute('aria-label', isPassword ? 'Ocultar senha' : 'Mostrar senha');
  });
}

// ── Carregamento dinâmico de Setores e Regiões cobertas ───────────────────
async function carregarSetoresERegioes() {
  try {
    const [setRes, regRes] = await Promise.all([
      fetch(`${apiUrl}/v1/setores`),
      fetch(`${apiUrl}/v1/regioes/cobertas`),
    ]);
    const setData = await setRes.json();
    const regData = await regRes.json();

    // ── Renderiza pills de setores ────────────────────────────────────────
    const setContainer = document.getElementById('setores-container');
    if (setContainer && Array.isArray(setData.setores)) {
      setContainer.innerHTML = '';
      if (setData.setores.length === 0) {
        setContainer.innerHTML = '<span class="text-xs text-gray-400">Nenhum setor cadastrado. Contate o administrador.</span>';
      } else {
        for (const s of setData.setores) {
          const label = document.createElement('label');
          label.className = 'cursor-pointer';
          label.innerHTML = `
            <input type="checkbox" name="setores" value="${s.nome}" class="sr-only peer setor-check" />
            <span class="inline-flex items-center px-3 py-1.5 rounded-full border border-gray-200 text-sm text-gray-700 peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:text-emerald-700 transition-colors select-none">${s.nome}</span>
          `;
          setContainer.appendChild(label);
        }
      }
    }

    // ── Popula dropdown de Estado ─────────────────────────────────────────
    const estadoSel = document.getElementById('estado_uf');
    const cidadeSel = document.getElementById('cidade');
    const cidadeIdEl = document.getElementById('cidade_id');
    const bairroInput = document.getElementById('neighborhood');
    const bairrosList = document.getElementById('bairros-list');

    if (estadoSel && Array.isArray(regData.regioes)) {
      estadoSel.innerHTML = '<option value="">Selecione o estado</option>';
      if (regData.regioes.length === 0) {
        estadoSel.innerHTML = '<option value="">Nenhuma região cadastrada</option>';
      } else {
        for (const est of regData.regioes) {
          const opt = document.createElement('option');
          opt.value = est.uf;
          opt.textContent = `${est.uf} — ${est.nome}`;
          opt.dataset.estadoId = est.id;
          estadoSel.appendChild(opt);
        }
      }

      // Quando estado muda, popula cidades
      estadoSel.addEventListener('change', () => {
        const estado = regData.regioes.find((e) => e.uf === estadoSel.value);
        cidadeSel.innerHTML = '<option value="">Selecione a cidade</option>';
        cidadeIdEl.value = '';
        bairrosList.innerHTML = '';
        if (bairroInput) { bairroInput.value = ''; bairroInput.placeholder = 'Selecione cidade primeiro'; }

        if (!estado || !estado.cidades || estado.cidades.length === 0) {
          cidadeSel.disabled = true;
          cidadeSel.innerHTML = '<option value="">Nenhuma cidade ativa neste estado</option>';
          return;
        }
        cidadeSel.disabled = false;
        for (const cid of estado.cidades) {
          const opt = document.createElement('option');
          opt.value = cid.nome;
          opt.textContent = cid.nome;
          opt.dataset.cidadeId = cid.id;
          opt.dataset.bairros  = JSON.stringify(cid.bairros ?? []);
          cidadeSel.appendChild(opt);
        }
      });

      // Quando cidade muda, popula datalist de bairros
      cidadeSel.addEventListener('change', () => {
        const opt = cidadeSel.options[cidadeSel.selectedIndex];
        cidadeIdEl.value = opt?.dataset.cidadeId ?? '';

        const bairrosCadastrados = JSON.parse(opt?.dataset.bairros ?? '[]');
        bairrosList.innerHTML = '';
        if (bairroInput) {
          bairroInput.value = '';
          if (bairrosCadastrados.length > 0) {
            for (const b of bairrosCadastrados) {
              const o = document.createElement('option');
              o.value = b.nome;
              bairrosList.appendChild(o);
            }
            bairroInput.placeholder = `Ex.: ${bairrosCadastrados.slice(0, 3).map((b) => b.nome).join(', ')}...`;
          } else {
            bairroInput.placeholder = 'Digite o nome do bairro';
          }
        }
      });
    }
  } catch (e) {
    console.error('[interesse-empresa] Falha ao carregar setores/regiões', e);
    const setContainer = document.getElementById('setores-container');
    if (setContainer) {
      setContainer.innerHTML = '<span class="text-xs text-red-500">Erro ao carregar setores. Recarregue a página.</span>';
    }
  }
}

// ── Fluxo principal ────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {

  // Carrega setores e regiões dinamicamente da API
  carregarSetoresERegioes();

  // ── Abas: clique direto nas tabs ───────────────────────────────────────
  document.getElementById('tab-empresa')?.addEventListener('click', () => ativarAba('empresa'));
  document.getElementById('tab-responsavel')?.addEventListener('click', () => {
    // Permitir navegar para responsável via clique direto (sem validação)
    ativarAba('responsavel');
  });

  // ── Botão Próximo ──────────────────────────────────────────────────────
  document.getElementById('btn-proximo')?.addEventListener('click', () => {
    if (!validarAba1()) {
      document.querySelector('#panel-empresa .border-red-400, #panel-empresa .text-red-500:not(.hidden)')
        ?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      return;
    }
    ativarAba('responsavel');
  });

  // ── Botão Voltar ───────────────────────────────────────────────────────
  document.getElementById('btn-voltar')?.addEventListener('click', () => ativarAba('empresa'));

  // ── CNPJ ───────────────────────────────────────────────────────────────
  const cnpjEl = document.getElementById('cnpj');

  cnpjEl?.addEventListener('input', async () => {
    cnpjEl.value = maskCNPJ(cnpjEl.value);
    const digits = cnpjEl.value.replace(/\D/g, '');

    // Enquanto o usuário edita (< 14 dígitos): limpa tudo
    if (digits.length < 14) {
      hideCnpjExistsBanner();
      resetCnpjIndicators();
      _lastLookedUpCNPJ = '';
      return;
    }

    // Chegou em 14 dígitos e ainda não foi consultado
    if (digits.length === 14 && digits !== _lastLookedUpCNPJ) {
      const errIcon = document.getElementById('cnpj-err');
      const msgEl   = document.getElementById('cnpj-msg');

      if (!validarCNPJ(digits)) {
        resetCnpjIndicators();
        errIcon.classList.remove('hidden');
        msgEl.textContent = 'CNPJ inválido.';
        msgEl.className   = 'text-xs mt-1 text-red-500';
        msgEl.classList.remove('hidden');
        return;
      }

      _lastLookedUpCNPJ = digits; // marca antes da chamada para evitar duplo disparo
      await lookupCNPJ(digits);
    }
  });

  // blur: consulta apenas se ainda não foi buscado (ex.: CNPJ colado no campo)
  cnpjEl?.addEventListener('blur', async () => {
    const digits = cnpjEl.value.replace(/\D/g, '');
    if (digits.length !== 14 || digits === _lastLookedUpCNPJ) return;

    const errIcon = document.getElementById('cnpj-err');
    const msgEl   = document.getElementById('cnpj-msg');

    if (!validarCNPJ(digits)) {
      resetCnpjIndicators();
      errIcon.classList.remove('hidden');
      msgEl.textContent = 'CNPJ inválido.';
      msgEl.className   = 'text-xs mt-1 text-red-500';
      msgEl.classList.remove('hidden');
      return;
    }

    _lastLookedUpCNPJ = digits;
    await lookupCNPJ(digits);
  });

  // CEP: máscara + lookup ViaCEP ao sair do campo
  const cepEl = document.getElementById('cep');
  cepEl?.addEventListener('input', () => { cepEl.value = maskCEP(cepEl.value); });
  cepEl?.addEventListener('blur', async () => {
    const digits = cepEl.value.replace(/\D/g, '');
    if (digits.length === 8) await lookupCEP(digits);
  });

  // Número: somente dígitos
  document.getElementById('numero')?.addEventListener('input', e => {
    e.target.value = e.target.value.replace(/\D/g, '');
  });

  // WhatsApp mask
  const waEl  = document.getElementById('contact_whatsapp');
  const waMsg = document.getElementById('whatsapp-msg');
  waEl?.addEventListener('input', () => { waEl.value = maskPhone(waEl.value); });
  waEl?.addEventListener('blur', () => {
    if (!waEl.value) return;
    const v = validarPhone(waEl.value);
    setField(waEl, v, waMsg, v ? '' : 'Número inválido. Use (93) 9 9999-9999.');
  });

  // Email validation
  const emailEl  = document.getElementById('contact_email');
  const emailMsg = document.getElementById('email-msg');
  emailEl?.addEventListener('blur', () => {
    if (!emailEl.value) return;
    const v = validarEmail(emailEl.value);
    setField(emailEl, v, emailMsg, v ? '' : 'E-mail inválido. Verifique o formato.');
  });
  emailEl?.addEventListener('input', () => {
    if (emailEl.classList.contains('border-red-400') && validarEmail(emailEl.value))
      setField(emailEl, true, emailMsg, '');
  });

  // Uppercase: nome + cargo
  ['contact_name', 'contact_role'].forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('input', () => {
      const pos = el.selectionStart;
      el.value = el.value.toUpperCase();
      el.setSelectionRange(pos, pos);
    });
  });

  // Validação senha em tempo real
  const senhaEl   = document.getElementById('contact_password');
  const senhaMsg  = document.getElementById('senha-msg');
  const confirmEl = document.getElementById('contact_password_confirm');
  const confMsg   = document.getElementById('senha-confirm-msg');

  senhaEl?.addEventListener('blur', () => {
    if (!senhaEl.value) return;
    const ok = senhaEl.value.length >= 8;
    setField(senhaEl, ok, senhaMsg, ok ? '' : 'A senha deve ter no mínimo 8 caracteres.');
    // Re-valida confirmação se já foi preenchida
    if (confirmEl.value) {
      const match = confirmEl.value === senhaEl.value;
      setField(confirmEl, match, confMsg, match ? '' : 'As senhas não coincidem.');
    }
  });

  confirmEl?.addEventListener('blur', () => {
    if (!confirmEl.value) return;
    const match = confirmEl.value === senhaEl.value;
    setField(confirmEl, match, confMsg, match ? '' : 'As senhas não coincidem.');
  });

  // Toggle dos olhinhos
  setupPasswordToggle('btn-toggle-senha',         'contact_password',         'icon-toggle-senha');
  setupPasswordToggle('btn-toggle-senha-confirm', 'contact_password_confirm', 'icon-toggle-senha-confirm');

  // ── Submissão do formulário → abre modal OTP ───────────────────────────
  const form   = document.getElementById('form-interesse');
  const btnSub = document.getElementById('btn-submit');
  const errBox = document.getElementById('form-error');
  const errMsg = document.getElementById('form-error-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errBox.classList.add('hidden');

    if (!validarAba2()) {
      errMsg.textContent = 'Corrija os campos indicados antes de continuar.';
      errBox.classList.remove('hidden');
      errBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      return;
    }

    btnSub.disabled = true;
    btnSub.innerHTML = '<i class="ri-loader-4-line motion-safe:animate-spin" aria-hidden="true"></i> Enviando código...';

    const dados = coletarDados();
    _phone = dados.contact_whatsapp;

    try {
      const res  = await fetch(`${apiUrl}/v1/interesse/send-code`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: _phone }),
      });
      const json = await res.json();

      if (!res.ok) throw new Error(json.error ?? 'Erro ao enviar código.');

      document.getElementById('otp-phone-display').textContent = json.maskedPhone ?? _phone;
      document.getElementById('otp-input').value = '';
      document.getElementById('otp-error').classList.add('hidden');
      iniciarTimer();
      showModal('modal-otp');
    } catch (err) {
      errMsg.textContent = err.message;
      errBox.classList.remove('hidden');
    } finally {
      btnSub.disabled = false;
      btnSub.innerHTML = '<i class="ri-send-plane-line" aria-hidden="true"></i> Enviar Solicitação';
    }
  });

  // ── Verificar código OTP ───────────────────────────────────────────────
  document.getElementById('btn-verificar')?.addEventListener('click', async () => {
    const codigo   = document.getElementById('otp-input').value.trim();
    const errEl    = document.getElementById('otp-error');
    const btnVerif = document.getElementById('btn-verificar');

    if (codigo.length !== 6) {
      errEl.textContent = 'Digite os 6 dígitos do código.';
      errEl.classList.remove('hidden');
      return;
    }

    btnVerif.disabled = true;
    btnVerif.innerHTML = '<i class="ri-loader-4-line motion-safe:animate-spin" aria-hidden="true"></i> Verificando...';
    errEl.classList.add('hidden');

    try {
      const res  = await fetch(`${apiUrl}/v1/interesse/verify-code`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: _phone, code: codigo }),
      });
      const json = await res.json();

      if (!res.ok) throw new Error(json.error ?? 'Código inválido.');

      _sessionId = json.sessionId;
      hideModal('modal-otp');

      const dados = coletarDados();
      preencherResumo(dados);
      document.getElementById('resumo-error').classList.add('hidden');
      showModal('modal-resumo');
    } catch (err) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
    } finally {
      btnVerif.disabled = false;
      btnVerif.innerHTML = '<i class="ri-shield-check-line" aria-hidden="true"></i> Verificar Código';
    }
  });

  // Enter no campo OTP aciona verificação
  document.getElementById('otp-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('btn-verificar')?.click();
  });

  // ── Reenviar código ────────────────────────────────────────────────────
  document.getElementById('btn-reenviar')?.addEventListener('click', async () => {
    const errEl = document.getElementById('otp-error');
    errEl.classList.add('hidden');
    iniciarTimer();
    try {
      const res  = await fetch(`${apiUrl}/v1/interesse/send-code`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: _phone }),
      });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error ?? 'Erro ao reenviar.');
    } catch (err) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
    }
  });

  // ── Cancelar OTP → volta para o form ──────────────────────────────────
  document.getElementById('btn-otp-cancelar')?.addEventListener('click', () => {
    clearInterval(_timerInterval);
    hideAllModals();
  });

  // ── Fechar resumo → volta para o form (invalida sessão) ────────────────
  document.getElementById('btn-resumo-fechar')?.addEventListener('click', () => {
    clearSession();
    hideAllModals();
  });

  // ── Confirmar pré-cadastro ─────────────────────────────────────────────
  document.getElementById('btn-confirmar')?.addEventListener('click', async () => {
    const errEl  = document.getElementById('resumo-error');
    const btnCon = document.getElementById('btn-confirmar');

    if (!_sessionId) {
      errEl.textContent = 'Sessão expirada. Reenvie o formulário.';
      errEl.classList.remove('hidden');
      return;
    }

    btnCon.disabled = true;
    btnCon.innerHTML = '<i class="ri-loader-4-line motion-safe:animate-spin" aria-hidden="true"></i> Enviando...';

    try {
      const dados = coletarDados();
      const res   = await fetch(`${apiUrl}/v1/interesse/submit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...dados, sessionId: _sessionId, phone: _phone }),
      });
      const json  = await res.json();

      // CITY_NOT_COVERED — cidade da operação não está coberta.
      // TODO Bloco 3: oferecer cadastro como Empresa Potencial. Por ora, mostra mensagem clara.
      if (res.status === 422 && json.error === 'CITY_NOT_COVERED') {
        errEl.textContent = json.message ?? 'Cidade da operação ainda não atendida.';
        errEl.classList.remove('hidden');
        return;
      }

      if (!res.ok) throw new Error(json.message ?? json.error ?? 'Erro ao enviar.');

      _sessionId = null;

      // Exibe o e-mail no modal de sucesso
      const emailEl = document.getElementById('sucesso-email');
      if (emailEl) emailEl.textContent = json.email ?? dados.contact_email ?? '';

      hideModal('modal-resumo');
      showModal('modal-sucesso');
    } catch (err) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
    } finally {
      btnCon.disabled = false;
      btnCon.innerHTML = '<i class="ri-check-double-line" aria-hidden="true"></i> Confirmar Pré-Cadastro';
    }
  });

  // Fecha modal backdrop OTP
  document.getElementById('otp-backdrop')?.addEventListener('click', () => {
    clearInterval(_timerInterval);
    hideAllModals();
  });

}); // DOMContentLoaded
</script>
