---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase } from '../lib/supabase';

export const prerender = true;

// ── Helper: arredonda para baixo no múltiplo de 50, mínimo 20 ────────────────
function roundedStat(n: number): string {
  if (n <= 0) return '20+';
  const rounded = Math.max(20, Math.floor(n / 50) * 50);
  return rounded.toLocaleString('pt-BR') + '+';
}

// ── Contagens reais do Supabase (com fallback) ────────────────────────────────
let companyCount   = 320;
let candidateCount = 8500;

try {
  const { count } = await supabase.from('companies').select('*', { count: 'exact', head: true });
  if (count !== null && count > 0) companyCount = count;
} catch { /* fallback */ }

try {
  const { count } = await supabase.from('profiles').select('*', { count: 'exact', head: true });
  if (count !== null && count > 0) candidateCount = count;
} catch { /* fallback */ }

const stats = [
  { value: roundedStat(companyCount),   label: 'Empresas parceiras' },
  { value: roundedStat(candidateCount), label: 'Candidatos ativos' },
  { value: 'Centenas',                  label: 'de Contratações realizadas' },
  { value: '<48h',                      label: 'Candidaturas com retorno rápido' },
];

// Setores e regiões agora vêm da API (Painel-admin gerencia em /vo-painel/setores e /regioes)
// Carregamento via fetch no client-side (DOMContentLoaded). Lista hardcoded removida.

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3001';
const apiUrl = import.meta.env.PUBLIC_API_URL  ?? 'http://localhost:3000';
---

<BaseLayout
  title="Falar com a Equipe VagasOeste — Interesse de Empresa"
  description="Entre em contato com a VagasOeste para contratar funcionários em Santarém/PA. Preencha o formulário e nossa equipe retorna em até 1 dia útil."
  keywords="contratar funcionários Santarém, contato VagasOeste, interesse empresa RH Pará"
>

  <section class="pt-20 pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <nav aria-label="breadcrumb" class="mb-8">
        <ol class="flex items-center gap-1.5 text-xs text-gray-500">
          <li><a href="/" class="hover:text-emerald-600 transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line" aria-hidden="true"></i></li>
          <li><a href="/para-empresas" class="hover:text-emerald-600 transition-colors">Para Empresas</a></li>
          <li><i class="ri-arrow-right-s-line" aria-hidden="true"></i></li>
          <li class="text-gray-900 font-medium">Falar com a Equipe</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

        <!-- ── Formulário ──────────────────────────────────────────────────── -->
        <div class="lg:col-span-3" id="form-wrapper">
          <h1 class="text-2xl font-bold text-gray-900 mb-2 text-balance">Quero contratar pela VagasOeste</h1>
          <p class="text-sm text-gray-600 mb-6 text-pretty">
            Preencha o formulário abaixo. Nossa equipe retorna em até 1 dia útil para criar sua conta e configurar as vagas.
          </p>

          <!-- ── Abas ──────────────────────────────────────────────────────── -->
          <div class="flex gap-1 bg-gray-100 p-1 rounded-xl mb-6" role="tablist" aria-label="Seções do formulário">
            <button
              type="button"
              role="tab"
              id="tab-empresa"
              aria-controls="panel-empresa"
              aria-selected="true"
              class="tab-btn flex-1 flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg text-sm font-medium transition-colors bg-white text-gray-900 shadow-sm"
            >
              <i class="ri-building-line text-emerald-600" aria-hidden="true"></i>
              Dados da Empresa
            </button>
            <button
              type="button"
              role="tab"
              id="tab-responsavel"
              aria-controls="panel-responsavel"
              aria-selected="false"
              class="tab-btn flex-1 flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700"
            >
              <i class="ri-user-line" aria-hidden="true"></i>
              Responsável pelo Contato
            </button>
          </div>

          <form id="form-interesse" class="space-y-6" novalidate>

            <!-- ══════════════════════════════════════════════════════════════
                 PAINEL 1 — Dados da Empresa
            ══════════════════════════════════════════════════════════════════ -->
            <div id="panel-empresa" role="tabpanel" aria-labelledby="tab-empresa">

              <!-- Banner: CNPJ já cadastrado (oculto por padrão) -->
              <div id="cnpj-exists-banner" class="hidden mb-4 bg-amber-50 border border-amber-200 rounded-xl p-4" role="alert" aria-live="polite">
                <div class="flex items-start gap-3">
                  <div class="size-8 rounded-lg bg-amber-100 flex items-center justify-center shrink-0 mt-0.5">
                    <i class="ri-information-line text-amber-600" aria-hidden="true"></i>
                  </div>
                  <div class="min-w-0">
                    <p id="cnpj-exists-title" class="text-sm font-bold text-amber-900 text-balance"></p>
                    <p id="cnpj-exists-msg"   class="text-xs text-amber-700 mt-0.5 text-pretty"></p>
                    <a
                      id="cnpj-exists-link"
                      href="#"
                      class="inline-flex items-center gap-1.5 mt-2.5 text-xs font-semibold text-emerald-700 hover:text-emerald-900 underline-offset-2 hover:underline transition-colors"
                    >
                      <i class="ri-login-box-line" aria-hidden="true"></i>
                      <span id="cnpj-exists-link-text"></span>
                    </a>
                  </div>
                </div>
              </div>

              <!-- CNPJ -->
              <div class="mb-4">
                <label for="cnpj" class="block text-xs font-medium text-gray-700 mb-1">CNPJ *</label>
                <div class="relative">
                  <input id="cnpj" name="cnpj" type="text" inputmode="numeric" maxlength="18"
                    placeholder="00.000.000/0001-00"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors pr-10"
                  />
                  <span id="cnpj-spinner" class="absolute right-3 top-1/2 -translate-y-1/2 hidden" role="status" aria-label="Consultando CNPJ"><i class="ri-loader-4-line motion-safe:animate-spin text-emerald-500" aria-hidden="true"></i></span>
                  <span id="cnpj-ok"      class="absolute right-3 top-1/2 -translate-y-1/2 hidden"><i class="ri-checkbox-circle-line text-emerald-500" aria-hidden="true"></i></span>
                  <span id="cnpj-err"     class="absolute right-3 top-1/2 -translate-y-1/2 hidden"><i class="ri-error-warning-line text-red-400" aria-hidden="true"></i></span>
                </div>
                <p id="cnpj-msg" class="text-xs mt-1 hidden"></p>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Razão Social (auto-fill via CNPJ) -->
                <div class="sm:col-span-2">
                  <label for="razao_social" class="block text-xs font-medium text-gray-700 mb-1">
                    Razão Social *
                    <span class="text-gray-400 font-normal ml-1">(preenchida automaticamente via CNPJ)</span>
                  </label>
                  <input id="razao_social" name="razao_social" type="text" readonly
                    placeholder="Digite o CNPJ acima para preencher"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none bg-gray-50 transition-colors"
                  />
                  <p id="razao-social-msg" class="text-xs mt-1 hidden"></p>
                </div>

                <!-- Nome Fantasia -->
                <div class="sm:col-span-2">
                  <label for="company_name" class="block text-xs font-medium text-gray-700 mb-1">
                    Nome Fantasia / Nome da Empresa *
                  </label>
                  <input id="company_name" name="company_name" type="text" required
                    placeholder="Empresa LTDA"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                  />
                </div>

                <!-- Estado e Cidade da OPERAÇÃO (dropdowns alimentados pelas Regiões cobertas) -->
                <div class="sm:col-span-2">
                  <p class="text-xs text-emerald-700 mb-2 leading-relaxed bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2">
                    <i class="ri-map-pin-line mr-1" aria-hidden="true"></i>
                    Selecione o <strong>Estado</strong> e a <strong>Cidade</strong> onde sua empresa opera. Não é necessariamente o endereço fiscal do CNPJ.
                  </p>
                </div>
                <div>
                  <label for="estado_uf" class="block text-xs font-medium text-gray-700 mb-1">Estado da operação *</label>
                  <select id="estado_uf" name="estado_uf" required
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors bg-white"
                  >
                    <option value="">Carregando...</option>
                  </select>
                </div>
                <div>
                  <label for="cidade" class="block text-xs font-medium text-gray-700 mb-1">Cidade da operação *</label>
                  <select id="cidade" name="cidade" required disabled
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors bg-white disabled:opacity-50 disabled:cursor-not-allowed"
                  >
                    <option value="">Selecione um estado primeiro</option>
                  </select>
                  <input type="hidden" id="cidade_id" name="cidade_id" />
                </div>

                <!-- Bairro Atual -->
                <div class="sm:col-span-2">
                  <label for="neighborhood" class="block text-xs font-medium text-gray-700 mb-1">
                    Bairro de operação *
                    <span class="text-gray-400 font-normal ml-1">(escolha cadastrado, ou digite outro)</span>
                  </label>
                  <input id="neighborhood" name="neighborhood" type="text" required
                    placeholder="Selecione cidade primeiro"
                    list="bairros-list"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                  />
                  <datalist id="bairros-list"></datalist>
                </div>
              </div>

              <!-- Endereço fiscal (auto-fill via CNPJ / busca por CEP) -->
              <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
                <!-- CEP: editável + lookup ViaCEP -->
                <div>
                  <label for="cep" class="block text-xs font-medium text-gray-700 mb-1">CEP</label>
                  <div class="relative">
                    <input id="cep" name="cep" type="text" inputmode="numeric" maxlength="9"
                      placeholder="00000-000"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors pr-8"
                    />
                    <span id="cep-spinner" class="absolute right-2.5 top-1/2 -translate-y-1/2 hidden">
                      <i class="ri-loader-4-line motion-safe:animate-spin text-emerald-500 text-sm" aria-hidden="true"></i>
                    </span>
                  </div>
                </div>
                <!-- Logradouro: preenchido via CNPJ ou CEP -->
                <div class="sm:col-span-2">
                  <label for="logradouro" class="block text-xs font-medium text-gray-700 mb-1">
                    Logradouro <span class="text-gray-400 font-normal">(auto)</span>
                  </label>
                  <input id="logradouro" name="logradouro" type="text" readonly
                    placeholder="Preenchido via CNPJ ou CEP"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-gray-50 focus:outline-none transition-colors"
                  />
                </div>
                <!-- Número: preenchido via CNPJ, editável -->
                <div>
                  <label for="numero" class="block text-xs font-medium text-gray-700 mb-1">Número</label>
                  <input id="numero" name="numero" type="text" inputmode="numeric" maxlength="6"
                    placeholder="S/N"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                  />
                </div>
                <!-- Bairro fiscal: preenchido via CNPJ ou CEP -->
                <div class="sm:col-span-2">
                  <label for="bairro_empresa" class="block text-xs font-medium text-gray-700 mb-1">
                    Bairro fiscal <span class="text-gray-400 font-normal">(auto)</span>
                  </label>
                  <input id="bairro_empresa" name="bairro_empresa" type="text" readonly
                    placeholder="Preenchido via CNPJ ou CEP"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-gray-50 focus:outline-none transition-colors"
                  />
                </div>
              </div>

              <!-- Setores de atuação (multi-select pills — populado via fetch /v1/setores) -->
              <div class="mt-4">
                <label class="block text-xs font-medium text-gray-700 mb-2">
                  Setor(es) de atuação *
                  <span class="text-gray-400 font-normal ml-1">(selecione um ou mais)</span>
                </label>
                <div id="setores-container" class="flex flex-wrap gap-2">
                  <span class="text-xs text-gray-400">Carregando setores...</span>
                </div>
                <p id="setores-msg" class="text-xs mt-1.5 text-red-500 hidden">Selecione ao menos um setor.</p>
              </div>

              <!-- Botão próximo -->
              <div class="mt-8">
                <button type="button" id="btn-proximo"
                  class="btn-primary w-full justify-center py-3 text-base"
                >
                  Próximo — Responsável pelo Contato
                  <i class="ri-arrow-right-line" aria-hidden="true"></i>
                </button>
              </div>
            </div>

            <!-- ══════════════════════════════════════════════════════════════
                 PAINEL 2 — Responsável pelo Contato + Informações Adicionais
            ══════════════════════════════════════════════════════════════════ -->
            <div id="panel-responsavel" role="tabpanel" aria-labelledby="tab-responsavel" class="hidden">

              <!-- Responsável pelo Contato -->
              <fieldset>
                <legend class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100 w-full flex items-center gap-2">
                  <i class="ri-user-line text-emerald-600" aria-hidden="true"></i>
                  Responsável pelo Contato
                </legend>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="contact_name" class="block text-xs font-medium text-gray-700 mb-1">Nome *</label>
                    <input id="contact_name" name="contact_name" type="text" required autocomplete="name"
                      style="text-transform: uppercase"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                    />
                  </div>
                  <div>
                    <label for="contact_role" class="block text-xs font-medium text-gray-700 mb-1">Cargo *</label>
                    <input id="contact_role" name="contact_role" type="text" required
                      placeholder="GERENTE DE RH"
                      style="text-transform: uppercase"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                    />
                  </div>
                  <div>
                    <label for="contact_email" class="block text-xs font-medium text-gray-700 mb-1">Email *</label>
                    <input id="contact_email" name="contact_email" type="email" required autocomplete="email"
                      placeholder="email@empresa.com"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                    />
                    <p id="email-msg" class="text-xs mt-1 hidden"></p>
                  </div>
                  <div>
                    <label for="contact_whatsapp" class="block text-xs font-medium text-gray-700 mb-1">WhatsApp *</label>
                    <input id="contact_whatsapp" name="contact_whatsapp" type="tel" required
                      inputmode="tel" maxlength="16" autocomplete="tel"
                      placeholder="(93) 9 9999-9999"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors"
                    />
                    <p id="whatsapp-msg" class="text-xs mt-1 hidden"></p>
                  </div>

                  <!-- Senha Plataforma -->
                  <div>
                    <label for="contact_password" class="block text-xs font-medium text-gray-700 mb-1">
                      Senha Plataforma *
                    </label>
                    <div class="relative">
                      <input id="contact_password" name="contact_password" type="password" required
                        autocomplete="new-password" minlength="8"
                        placeholder="Mínimo 8 caracteres"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors pr-10"
                      />
                      <button
                        type="button"
                        id="btn-toggle-senha"
                        aria-label="Mostrar senha"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors"
                      >
                        <i id="icon-toggle-senha" class="ri-eye-line text-base" aria-hidden="true"></i>
                      </button>
                    </div>
                    <p id="senha-msg" class="text-xs mt-1 hidden"></p>
                  </div>

                  <!-- Confirmar Senha -->
                  <div>
                    <label for="contact_password_confirm" class="block text-xs font-medium text-gray-700 mb-1">
                      Confirmar Senha *
                    </label>
                    <div class="relative">
                      <input id="contact_password_confirm" name="contact_password_confirm" type="password" required
                        autocomplete="new-password" minlength="8"
                        placeholder="Repita a senha"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors pr-10"
                      />
                      <button
                        type="button"
                        id="btn-toggle-senha-confirm"
                        aria-label="Mostrar confirmação de senha"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors"
                      >
                        <i id="icon-toggle-senha-confirm" class="ri-eye-line text-base" aria-hidden="true"></i>
                      </button>
                    </div>
                    <p id="senha-confirm-msg" class="text-xs mt-1 hidden"></p>
                  </div>
                </div>
              </fieldset>

              <!-- Informações Adicionais -->
              <fieldset class="mt-6">
                <legend class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100 w-full flex items-center gap-2">
                  <i class="ri-information-line text-emerald-600" aria-hidden="true"></i>
                  Informações Adicionais
                </legend>
                <div class="space-y-4">
                  <div>
                    <label class="block text-xs font-medium text-gray-700 mb-2">
                      Quantas vagas pretende publicar? *
                    </label>
                    <div class="flex flex-wrap gap-2" id="vagas-container">
                      {['1 a 3', '4 a 10', '11 a 30', 'Mais de 30'].map((qty) => (
                        <label class="cursor-pointer">
                          <input type="radio" name="vacancies_qty" value={qty} class="sr-only peer vagas-radio" />
                          <span class="inline-flex items-center px-4 py-2 rounded-full border border-gray-200 text-sm text-gray-700 peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:text-emerald-700 transition-colors select-none">
                            {qty}
                          </span>
                        </label>
                      ))}
                    </div>
                    <p id="vagas-msg" class="text-xs mt-1.5 text-red-500 hidden">Selecione a quantidade de vagas.</p>
                  </div>
                  <div>
                    <label for="message" class="block text-xs font-medium text-gray-700 mb-1">Mensagem (opcional)</label>
                    <textarea id="message" name="message" rows={3}
                      placeholder="Conte mais sobre suas necessidades de contratação..."
                      class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-emerald-500 transition-colors resize-none"
                    ></textarea>
                  </div>
                </div>
              </fieldset>

              <!-- Erro global -->
              <div id="form-error" class="hidden mt-4 bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700 flex items-center gap-2">
                <i class="ri-error-warning-line shrink-0" aria-hidden="true"></i>
                <span id="form-error-msg"></span>
              </div>

              <!-- Rodapé: voltar + enviar -->
              <div class="mt-6 flex flex-col sm:flex-row gap-3">
                <button type="button" id="btn-voltar"
                  class="sm:w-auto flex items-center justify-center gap-2 px-5 py-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors"
                >
                  <i class="ri-arrow-left-line" aria-hidden="true"></i>
                  Voltar
                </button>
                <button type="submit" id="btn-submit" class="btn-primary flex-1 justify-center py-3 text-base">
                  <i class="ri-send-plane-line" aria-hidden="true"></i>
                  Enviar Solicitação
                </button>
              </div>
              <p class="text-xs text-gray-400 text-center mt-3">
                Após o envio, você receberá um código via WhatsApp para validar seu pré-cadastro.
              </p>
            </div>

          </form>
        </div>

        <!-- ── Sidebar ─────────────────────────────────────────────────────── -->
        <aside class="lg:col-span-2 space-y-5">
          <!-- Contato direto -->
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5">
            <h2 class="font-semibold text-gray-900 mb-3 flex items-center gap-2 text-balance">
              <i class="ri-customer-service-2-line text-emerald-600" aria-hidden="true"></i>
              Prefere falar direto?
            </h2>
            <div class="space-y-3">
              <a href="https://wa.me/559399999000" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 bg-white rounded-lg p-3 border border-emerald-100 hover:border-emerald-300 transition-colors">
                <i class="ri-whatsapp-line text-2xl text-green-500" aria-hidden="true"></i>
                <div>
                  <p class="text-xs font-semibold text-gray-900">(93) 99999-0000</p>
                  <p class="text-xs text-gray-500">WhatsApp — Seg a Sex, 8h–18h</p>
                </div>
              </a>
              <a href="mailto:empresas@santarem.app"
                class="flex items-center gap-3 bg-white rounded-lg p-3 border border-emerald-100 hover:border-emerald-300 transition-colors">
                <i class="ri-mail-line text-2xl text-emerald-500" aria-hidden="true"></i>
                <div>
                  <p class="text-xs font-semibold text-gray-900">empresas@santarem.app</p>
                  <p class="text-xs text-gray-500">Resposta em até 24h</p>
                </div>
              </a>
            </div>
          </div>

          <!-- Benefícios -->
          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <h2 class="font-semibold text-gray-900 mb-3">Por que a VagasOeste?</h2>
            <ul class="space-y-3">
              {[
                { icon: 'ri-shield-user-line',       text: 'Candidatos verificados pela equipe' },
                { icon: 'ri-eye-off-line',            text: 'Sua empresa fica anônima para os candidatos' },
                { icon: 'ri-group-line',              text: `Acesso a ${roundedStat(candidateCount)} candidatos em Santarém e região` },
                { icon: 'ri-time-line',               text: 'Publique sua vaga em minutos' },
                { icon: 'ri-customer-service-2-line', text: 'Suporte dedicado da nossa equipe' },
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <i class={`${item.icon} text-emerald-500 shrink-0 mt-0.5`} aria-hidden="true"></i>
                  {item.text}
                </li>
              ))}
            </ul>
          </div>

