---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSearch from '../components/islands/HeroSearch';
import HomepageJobs from '../components/islands/HomepageJobs';
import TestimonialsSlider from '../components/islands/TestimonialsSlider';
import SectorCards from '../components/islands/SectorCards';
import { getAllJobs, getUniqueSectors } from '../lib/jobs';
import { supabase } from '../lib/supabase';
import { getFeaturedPosts } from '../lib/blog';
import { buildWebSiteSchema, buildLocalBusinessSchema } from '../lib/schemas';

// SSG — gerado em build time
export const prerender = true;

const jobs = await getAllJobs();
const featuredPosts = await getFeaturedPosts(3);
const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://app.santarem.app';

// Mock fallback para quando o Supabase ainda não tiver vagas cadastradas
const mockFallbackJobs = [
  { id: '1', title: 'Auxiliar Administrativo', sector: 'Comércio', area: 'Administrativo', contractType: 'CLT', neighborhood: 'Centro', city: 'Santarém', state: 'PA', salaryRange: 'R$ 1.800 – R$ 2.200', description: 'Apoio em rotinas administrativas, controle de documentos e atendimento interno.', requirements: 'Ensino médio completo, pacote Office básico', tags: [], isActive: true, createdAt: '2026-04-10' },
  { id: '2', title: 'Operador de Caixa', sector: 'Comércio', area: 'Varejo', contractType: 'CLT', neighborhood: 'Maracanã', city: 'Santarém', state: 'PA', salaryRange: 'R$ 1.600 – R$ 1.900', description: 'Atendimento ao cliente, operação de caixa e controle de troco.', requirements: 'Ensino médio completo, experiência em varejo', tags: [], isActive: true, createdAt: '2026-04-11' },
  { id: '3', title: 'Motorista Entregador', sector: 'Logística', area: 'Logística', contractType: 'CLT', neighborhood: 'Jardim Santarém', city: 'Santarém', state: 'PA', salaryRange: 'R$ 2.200 – R$ 2.800', description: 'Entrega de mercadorias na região de Santarém, uso de aplicativo de rotas.', requirements: 'CNH B, experiência com entregas', tags: [], isActive: true, createdAt: '2026-04-12' },
  { id: '4', title: 'Recepcionista', sector: 'Saúde', area: 'Atendimento', contractType: 'CLT', neighborhood: 'Aldeia', city: 'Santarém', state: 'PA', salaryRange: 'R$ 1.700 – R$ 2.100', description: 'Recepção de clientes, agendamentos e suporte à equipe administrativa.', requirements: 'Ensino médio completo, boa comunicação', tags: [], isActive: true, createdAt: '2026-04-12' },
  { id: '5', title: 'Auxiliar de Limpeza', sector: 'Serviços', area: 'Serviços Gerais', contractType: 'CLT', neighborhood: 'Santa Clara', city: 'Santarém', state: 'PA', salaryRange: 'R$ 1.500 – R$ 1.700', description: 'Limpeza e conservação de ambientes comerciais e industriais.', requirements: 'Ensino fundamental, experiência na área', tags: [], isActive: true, createdAt: '2026-04-13' },
  { id: '6', title: 'Vendedor Externo', sector: 'Comércio', area: 'Vendas', contractType: 'PJ', neighborhood: 'Aparecida', city: 'Santarém', state: 'PA', salaryRange: 'R$ 2.500 – R$ 4.000 + comissão', description: 'Prospecção e atendimento de clientes na região de Santarém, metas mensais.', requirements: 'Experiência em vendas externas, CNH', tags: [], isActive: true, createdAt: '2026-04-13' },
  { id: '7', title: 'Técnico de Informática', sector: 'Tecnologia', area: 'TI', contractType: 'CLT', neighborhood: 'Centro', city: 'Santarém', state: 'PA', salaryRange: 'R$ 2.800 – R$ 3.500', description: 'Suporte técnico, manutenção de computadores e redes locais.', requirements: 'Curso técnico em TI, experiência em suporte', tags: [], isActive: true, createdAt: '2026-04-14' },
  { id: '8', title: 'Cozinheiro(a)', sector: 'Alimentação', area: 'Alimentação', contractType: 'CLT', neighborhood: 'Maracanã', city: 'Santarém', state: 'PA', salaryRange: 'R$ 2.000 – R$ 2.600', description: 'Preparo de refeições para restaurante de médio porte, cardápio variado.', requirements: 'Experiência em cozinha, curso de gastronomia desejável', tags: [], isActive: true, createdAt: '2026-04-14' },
];

const displayJobs = jobs.length > 0 ? jobs.slice(0, 8) : mockFallbackJobs;
const totalJobCount = jobs.length > 0 ? jobs.length : 12;

// Contagem de vagas reais por setor — passada para a island SectorCards
const rawSectorCounts = jobs.reduce((acc: Record<string, number>, job) => {
  if (job.sector) acc[job.sector] = (acc[job.sector] ?? 0) + 1;
  return acc;
}, {});

// Fallback mock para quando não há vagas no banco ainda
const mockSectorCounts: Record<string, number> = {
  'Comércio': 4, 'Logística': 2, 'Saúde': 1, 'Serviços': 1,
  'Tecnologia': 1, 'Alimentação': 1, 'Construção Civil': 1, 'Indústria': 1,
};

const sectorCounts = jobs.length > 0 ? rawSectorCounts : mockSectorCounts;

// Contagem de vagas por função/cargo — mesma lógica do filtro de JobsFilter
const FUNCOES_NAMES = [
  'Vendedor(a)', 'Auxiliar Administrativo', 'Recepcionista',
  'Operador de Caixa', 'Motorista/Entregador', 'Auxiliar de Limpeza',
  'Cozinheiro(a)', 'Manutenção/Eletricista',
];
const rawFuncaoCounts = FUNCOES_NAMES.reduce((acc: Record<string, number>, funcao) => {
  const fq = funcao.toLowerCase().replace(/\(.*?\)/g, '').trim().replace(/\//g, ' ');
  acc[funcao] = jobs.filter(j =>
    j.title.toLowerCase().includes(fq.split(' ')[0]) ||
    j.area.toLowerCase().includes(fq.split(' ')[0])
  ).length;
  return acc;
}, {});
const mockFuncaoCounts: Record<string, number> = {
  'Vendedor(a)': 3, 'Auxiliar Administrativo': 2, 'Recepcionista': 1,
  'Operador de Caixa': 1, 'Motorista/Entregador': 1, 'Auxiliar de Limpeza': 1,
  'Cozinheiro(a)': 1, 'Manutenção/Eletricista': 1,
};
const funcaoCounts = jobs.length > 0 ? rawFuncaoCounts : mockFuncaoCounts;

const stats = [
  { label: 'Vagas Ativas', value: `${totalJobCount}+` },
  { label: 'Candidatos Cadastrados', value: '8.500+' },
  { label: 'Empresas Parceiras', value: '320+' },
  { label: 'Contratações em 2026', value: '2.100+' },
];

const testimonials = [
  {
    id: 1,
    name: 'Fernanda Oliveira',
    role: 'Auxiliar Administrativa',
    neighborhood: 'Centro',
    text: 'Em menos de 2 semanas após me cadastrar na VagasOeste, recebi uma proposta de emprego no meu bairro. O processo foi super transparente!',
    initials: 'FO',
    color: 'bg-emerald-600',
  },
  {
    id: 2,
    name: 'Carlos Mendes',
    role: 'Motorista Entregador',
    neighborhood: 'Jardim Santarém',
    text: 'Achei incrível que a empresa ficou anônima até eu ser selecionado. Me senti mais seguro no processo. Hoje estou empregado há 4 meses!',
    initials: 'CM',
    color: 'bg-blue-600',
  },
  {
    id: 3,
    name: 'Juliana Santos',
    role: 'Recepcionista',
    neighborhood: 'Maracanã',
    text: 'A plataforma é muito fácil de usar. Me candidatei a 3 vagas de uma vez e fui chamada para entrevista em 2 delas. A VagasOeste realmente funciona!',
    initials: 'JS',
    color: 'bg-violet-600',
  },
];

const howItWorksSteps = [
  { icon: 'ri-user-add-line', title: 'Crie sua conta gratuitamente', desc: 'Cadastro rápido para montar seu perfil profissional.' },
  { icon: 'ri-search-eye-line', title: 'Explore as vagas disponíveis', desc: 'Filtre vagas por função/cargo, setor e tipo de contrato.' },
  { icon: 'ri-send-plane-line', title: 'Candidate-se com 1 clique', desc: 'Envio rápido, seguro e sem exposição de dados pessoais.' },
  { icon: 'ri-notification-3-line', title: 'Acompanhe em tempo real', desc: 'Receba atualizações por email e WhatsApp.' },
  { icon: 'ri-shield-check-line', title: 'Processo seguro', desc: 'Informações pessoais como nome, telefone e email não são compartilhadas durante o processo seletivo.' },
  { icon: 'ri-trophy-line', title: 'Avance até a contratação', desc: 'Ao ser selecionado, você segue diretamente com a empresa.' },
];

const affiliateCourses = [
  {
    title: 'Excel Completo',
    platform: 'Udemy',
    discount: '85% OFF',
    href: '#afiliado-excel',
    icon: 'ri-table-2',
    gradient: 'from-emerald-900 to-emerald-700',
  },
  {
    title: 'Inglês para o Mercado',
    platform: 'Hotmart',
    discount: '60% OFF',
    href: '#afiliado-ingles',
    icon: 'ri-translate-2',
    gradient: 'from-blue-900 to-blue-700',
  },
  {
    title: 'Pacote Office Profissional',
    platform: 'Hotmart',
    discount: '70% OFF',
    href: '#afiliado-office',
    icon: 'ri-computer-line',
    gradient: 'from-violet-900 to-violet-700',
  },
];

// Organization é injetado globalmente pelo BaseHead.
// Home recebe schemas extras: WebSite (sitelinks search box) + LocalBusiness (presença local).
const websiteSchema = buildWebSiteSchema();
const localBusinessSchema = buildLocalBusinessSchema();
---

<BaseLayout
  title="Vagas de Emprego em Santarém PA — VagasOeste"
  description="Encontre vagas de emprego em Santarém e região oeste do Pará. Processo seletivo anônimo e seguro. Mais de 1.240 vagas ativas. Candidate-se grátis."
  keywords="vagas em Santarém, emprego Santarém PA, vagas Pará, emprego oeste do Pará, vagas CLT Santarém"
  schema={[websiteSchema, localBusinessSchema]}
  transparentNav={true}
>

  <!-- ───────────────────────────── HERO ──────────────────────────── -->
  <section class="relative flex flex-col items-center justify-center overflow-hidden min-h-[480px]" aria-label="Busca de vagas">
    <div class="absolute inset-0 bg-gradient-to-b from-emerald-950 via-emerald-900 to-emerald-950">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_40%,rgba(16,185,129,0.18),transparent_65%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_60%,rgba(6,78,59,0.25),transparent_60%)]"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-6 pt-24 pb-10 flex flex-col items-center text-center">
      <h1 class="text-2xl md:text-4xl font-bold text-white leading-tight mb-3 max-w-2xl text-balance">
        As melhores vagas em{' '}
        <span class="text-emerald-300">Santarém e região</span>, em um só lugar
      </h1>
      <p class="text-white/75 text-sm md:text-base max-w-lg mb-6 leading-relaxed text-pretty">
        Vagas reais com informações claras sobre função e área de atuação. Acompanhe cada etapa da sua candidatura em tempo real.
      </p>

      <!-- Formulário de busca: ilha React -->
      <HeroSearch client:load />
    </div>
  </section>

  <!-- ─────────────────────────── STATS ─────────────────────────────── -->
  <section class="bg-emerald-600" aria-label="Números da plataforma">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-3">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-3 text-center text-white">
        {stats.map((stat) => (
          <div class="py-0.5">
            <dt class="text-xl md:text-2xl font-bold">{stat.value}</dt>
            <dd class="text-xs text-emerald-100 mt-0.5">{stat.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ─────────────────── ÁREAS DE ATUAÇÃO (Por Setor / Por Função) ── -->
  <section class="pt-14 pb-8 bg-white" aria-labelledby="setores-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <div>
          <span class="text-emerald-600 text-xs font-semibold uppercase tracking-widest">Áreas de atuação</span>
          <h2 id="setores-title" class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 text-balance">Explore por Setor ou Função</h2>
          <p class="text-gray-700 text-sm mt-2 max-w-md text-pretty">
            Selecione um setor ou função, escolha a localidade e veja as vagas disponíveis.
          </p>
        </div>
        <a href="/vagas" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700 flex items-center gap-1 whitespace-nowrap">
          Ver todas as vagas
          <i class="ri-arrow-right-line text-sm" aria-hidden="true"></i>
        </a>
      </div>

      <!-- Island interativa com abas + modal de localização -->
      <SectorCards client:load sectorCounts={sectorCounts} funcaoCounts={funcaoCounts} />

      <!-- Aviso de anonimato -->
      <div class="mt-8 flex items-center gap-3 bg-emerald-50 border border-emerald-100 rounded-xl p-4">
        <div class="size-8 flex items-center justify-center rounded-lg bg-emerald-100 shrink-0">
          <i class="ri-shield-check-line text-emerald-600 text-sm" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-emerald-800 text-pretty">
          <strong>Processo seguro:</strong> A empresa permanece anônima nas etapas iniciais e só é revelada quando você é selecionado, garantindo uma análise focada no seu perfil profissional.
        </p>
      </div>
    </div>
  </section>

  <!-- ─────────────────── VAGAS DISPONÍVEIS HOJE (layout plataforma) ── -->
  <section class="pt-8 pb-14 bg-gray-50" aria-labelledby="vagas-hoje-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <div>
          <span class="text-emerald-600 text-xs font-semibold uppercase tracking-widest">Oportunidades</span>
          <h2 id="vagas-hoje-title" class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 text-balance">Vagas Disponíveis Hoje</h2>
          <p class="text-gray-700 text-sm mt-2">
            Empresas verificadas – candidate-se com segurança.
          </p>
        </div>
        <a href="/vagas" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700 flex items-center gap-1 whitespace-nowrap">
          Ver todas as vagas
          <i class="ri-arrow-right-line text-sm" aria-hidden="true"></i>
        </a>
      </div>

      <HomepageJobs client:load jobs={displayJobs} appUrl={appUrl} totalCount={totalJobCount} />
    </div>
  </section>

  <!-- ─────────────────── COMO FUNCIONA ─────────────────────────────── -->
  <section class="py-14 bg-gray-50" aria-labelledby="como-funciona-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">Simples e seguro</p>
        <h2 id="como-funciona-title" class="text-2xl font-bold text-gray-900 mb-2 text-balance">Como Funciona</h2>
        <p class="text-sm text-gray-500 max-w-md mx-auto text-pretty">Do cadastro à contratação,<br class="hidden sm:block" /> com controle total em cada etapa.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {howItWorksSteps.map((step, i) => (
          <div class="flex gap-4 p-4">
            <div class="size-10 rounded-xl bg-emerald-100 flex items-center justify-center shrink-0">
              <i class={`${step.icon} text-emerald-600 text-xl`} aria-hidden="true"></i>
            </div>
            <div>
              <p class="text-sm font-bold text-emerald-600 mb-1">0{i + 1}</p>
              <h3 class="font-semibold text-gray-900 text-base mb-1 text-balance">{step.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed text-pretty">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA duplo: candidato / empresa -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-10 max-w-2xl mx-auto">
        <a
          href={`${appUrl}/cadastro`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center text-center gap-3 rounded-xl border-2 border-emerald-200 bg-emerald-50 hover:bg-emerald-100 hover:border-emerald-400 transition-colors p-6"
        >
          <div class="size-12 rounded-full bg-emerald-100 flex items-center justify-center">
            <i class="ri-user-search-line text-emerald-600 text-2xl" aria-hidden="true"></i>
          </div>
          <div>
            <p class="font-bold text-gray-900 text-base">Quero encontrar emprego</p>
            <p class="text-sm text-gray-500 mt-1">Crie sua conta grátis e candidate-se</p>
          </div>
        </a>
        <a
          href="/interesse-empresa"
          class="flex flex-col items-center text-center gap-3 rounded-xl border-2 border-gray-200 bg-white hover:bg-gray-50 hover:border-gray-300 transition-colors p-6"
        >
          <div class="size-12 rounded-full bg-gray-100 flex items-center justify-center">
            <i class="ri-building-2-line text-gray-600 text-2xl" aria-hidden="true"></i>
          </div>
          <div>
            <p class="font-bold text-gray-900 text-base">Quero contratar talentos</p>
            <p class="text-sm text-gray-500 mt-1">Publique vagas e encontre candidatos</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ─────────────────── CURSOS AFILIADOS ─────────────────────────── -->
  <section class="py-14" aria-labelledby="cursos-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">Desenvolvimento profissional</p>
        <h2 id="cursos-title" class="text-2xl font-bold text-gray-900 mb-2 text-balance">Aumente suas chances com cursos</h2>
        <p class="text-sm text-gray-500 max-w-md mx-auto text-pretty">
          Candidatos com certificações têm até <strong>3x mais chances</strong> de serem selecionados.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {affiliateCourses.map((course) => (
          <a
            href={course.href}
            rel="nofollow noopener noreferrer"
            target="_blank"
            class="group bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden block"
          >
            <div class="relative">
              <div class={`w-full h-44 bg-gradient-to-br ${course.gradient} flex items-center justify-center transition-opacity duration-300 group-hover:opacity-90`}>
                <i class={`${course.icon} text-5xl text-white/70`} aria-hidden="true"></i>
              </div>
              <span class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">
                {course.discount}
              </span>
            </div>
            <div class="p-5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 mb-2">
                {course.platform}
              </span>
              <h3 class="font-bold text-gray-900 text-sm leading-snug mb-3 text-balance">{course.title}</h3>
              <span class="text-sm font-semibold text-emerald-600 flex items-center gap-1">
                Ver curso <i class="ri-external-link-line text-xs" aria-hidden="true"></i>
              </span>
            </div>
          </a>
        ))}
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        * Links de afiliado — a VagasOeste pode receber comissão sem custo adicional para você.
      </p>
    </div>
  </section>

  <!-- ─────────────────── DEPOIMENTOS ──────────────────────────────── -->
  <section class="py-14 bg-gray-50" aria-labelledby="depoimentos-title">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">Histórias reais</p>
        <h2 id="depoimentos-title" class="text-2xl font-bold text-gray-900 text-balance">O que dizem nossos candidatos</h2>
      </div>
      <TestimonialsSlider client:visible testimonials={testimonials} />
    </div>
  </section>

  <!-- ─────────────────── BLOG ─────────────────────────────────────── -->
  {featuredPosts.length > 0 && (
    <section class="py-14" aria-labelledby="blog-title">
      <div class="max-w-7xl mx-auto px-4 md:px-6">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
          <div>
            <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">Dicas de carreira</p>
            <h2 id="blog-title" class="text-2xl font-bold text-gray-900 text-balance">Artigos em Destaque</h2>
          </div>
          <a href="/blog" class="btn-secondary text-sm">
            Ver todos os artigos <i class="ri-arrow-right-line" aria-hidden="true"></i>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredPosts.map((post) => (
            <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <a href={`/blog/${post.slug}`}>
                <img src={post.coverImage} alt={post.title} class="w-full h-44 object-cover" loading="lazy" />
              </a>
              <div class="p-5">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 mb-3">
                  {post.category}
                </span>
                <h3 class="font-bold text-gray-900 text-sm leading-snug mb-2 line-clamp-2 text-balance">
                  <a href={`/blog/${post.slug}`} class="hover:text-emerald-600 transition-colors">{post.title}</a>
                </h3>
                <p class="text-xs text-gray-500 line-clamp-2">{post.excerpt}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─────────────────── CTA FINAL ─────────────────────────────────── -->
  <section class="relative overflow-hidden py-20" aria-label="Chamada para ação final">
    <div class="absolute inset-0 bg-gradient-to-r from-emerald-950 to-emerald-900">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_50%,rgba(16,185,129,0.15),transparent_60%)]"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight text-balance">
        Sua próxima oportunidade está <span class="text-emerald-300">esperando por você</span>
      </h2>
      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-8 text-xs text-emerald-200">
        <span class="flex items-center gap-1.5">
          <i class="ri-check-line text-emerald-400" aria-hidden="true"></i>
          100% gratuito para candidatos
        </span>
        <span class="flex items-center gap-1.5">
          <i class="ri-whatsapp-line text-emerald-400" aria-hidden="true"></i>
          Alertas no WhatsApp
        </span>
        <span class="flex items-center gap-1.5">
          <i class="ri-shield-check-line text-emerald-400" aria-hidden="true"></i>
          Processo anônimo e seguro
