---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from '../../components/islands/BlogSearch';
import { getAllPosts, getFeaturedPosts, getCategories } from '../../lib/blog';

export const prerender = true;

const posts = await getAllPosts();
const featured = await getFeaturedPosts(2);
const categories = await getCategories();

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog VagasOeste — Dicas de Emprego em Santarém',
  description: 'Artigos sobre currículo, entrevistas, direitos trabalhistas e mercado de trabalho em Santarém e região oeste do Pará.',
  url: 'https://santarem.app/blog',
  publisher: {
    '@type': 'Organization',
    name: 'VagasOeste',
    logo: { '@type': 'ImageObject', url: 'https://santarem.app/logo.png' },
  },
  blogPost: posts.slice(0, 5).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `https://santarem.app/blog/${p.slug}`,
    datePublished: p.publishedAt,
    image: p.coverImage,
  })),
};
---

<BaseLayout
  title="Blog VagasOeste — Dicas de Emprego em Santarém PA"
  description="Artigos sobre currículo, entrevistas, direitos trabalhistas e mercado de trabalho em Santarém e região oeste do Pará. Dicas práticas para encontrar emprego."
  keywords="dicas emprego Santarém, currículo Pará, entrevista emprego, mercado trabalho Santarém, direitos trabalhistas"
  schema={blogSchema}
>

  <!-- Hero -->
  <section class="bg-emerald-900 pt-24 pb-12 relative overflow-hidden" aria-label="Blog">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-900 via-emerald-950 to-gray-900">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_40%,rgba(16,185,129,0.12),transparent_65%)]"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-xs text-emerald-300">
          <li><a href="/" class="hover:text-white transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-white font-medium">Blog</li>
        </ol>
      </nav>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">Blog VagasOeste</h1>
      <p class="text-emerald-200 text-sm max-w-lg">
        Dicas de currículo, entrevistas, mercado de trabalho e carreira para candidatos de Santarém e região.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 md:px-6 py-10">

    <!-- Posts em destaque -->
    {featured.length > 0 && (
      <section aria-labelledby="destaques-title" class="mb-12">
        <h2 id="destaques-title" class="text-lg font-bold text-gray-900 mb-4">
          <i class="ri-star-line text-amber-500 mr-1"></i>
          Artigos em Destaque
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featured.map((post) => (
            <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
              <a href={`/blog/${post.slug}`} class="block">
                <img src={post.coverImage} alt={post.title} class="w-full h-52 object-cover" loading="lazy" />
              </a>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">
                    {post.category}
                  </span>
                  <span class="text-xs text-gray-400">{post.readTime} min</span>
                </div>
                <h3 class="font-bold text-gray-900 text-lg leading-snug mb-2 flex-1">
                  <a href={`/blog/${post.slug}`} class="hover:text-emerald-600 transition-colors">{post.title}</a>
                </h3>
                <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.excerpt}</p>
                <a href={`/blog/${post.slug}`} class="text-sm font-semibold text-emerald-600 hover:text-emerald-700 flex items-center gap-1">
                  Ler artigo completo <i class="ri-arrow-right-line"></i>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Todos os artigos com busca (ilha React) -->
    <section aria-labelledby="todos-artigos-title">
      <h2 id="todos-artigos-title" class="text-lg font-bold text-gray-900 mb-6">Todos os Artigos</h2>
      <BlogSearch client:load initialPosts={posts} categories={categories} />
    </section>

    <!-- CTA -->
    <section class="mt-10 bg-emerald-600 rounded-2xl p-5 md:p-7 text-center" aria-label="Criar conta">
      <h2 class="text-lg md:text-xl font-bold text-white mb-2">
        Pronto para encontrar seu próximo emprego?
      </h2>
      <p class="text-white/90 text-xs md:text-sm mb-4 max-w-lg mx-auto leading-relaxed">
        Cadastre-se gratuitamente na VagasOeste e tenha acesso às melhores vagas de Santarém e região, com processo seletivo transparente e intermediado por profissionais.
      </p>
      <div class="flex flex-col sm:flex-row gap-2 justify-center">
        <button
          type="button"
          onclick="window.dispatchEvent(new CustomEvent('openRegisterModal'))"
          class="bg-white text-emerald-700 font-bold px-5 py-2 rounded-xl hover:bg-emerald-50 transition-colors text-sm whitespace-nowrap"
        >
          Criar Cadastro Grátis
        </button>
        <a
          href="/vagas"
          class="border border-white/40 text-white font-semibold px-5 py-2 rounded-xl hover:bg-white/10 transition-colors text-sm whitespace-nowrap"
        >
          Ver vagas disponíveis
        </a>
      </div>
    </section>
  </div>

</BaseLayout>
