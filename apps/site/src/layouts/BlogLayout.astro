---
import BaseLayout from './BaseLayout.astro';
import type { BlogPost } from '../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  author: {
    '@type': 'Organization',
    name: post.author,
    url: 'https://santarem.app',
  },
  publisher: {
    '@type': 'Organization',
    name: 'VagasOeste',
    logo: {
      '@type': 'ImageObject',
      url: 'https://santarem.app/logo.png',
    },
  },
  image: post.coverImage,
  keywords: post.tags.join(', '),
  articleSection: post.category,
  url: `https://santarem.app/blog/${post.slug}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://santarem.app/blog/${post.slug}`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://santarem.app/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://santarem.app/blog' },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://santarem.app/blog/${post.slug}` },
  ],
};
---

<BaseLayout
  title={`${post.title} | Blog VagasOeste`}
  description={post.excerpt}
  keywords={post.tags.join(', ')}
  schema={[articleSchema, breadcrumbSchema]}
  image={post.coverImage}
  type="article"
  publishedAt={post.publishedAt}
>
  <!-- Hero do Artigo -->
  <div class="relative pt-16">
    <div class="h-64 md:h-80 relative overflow-hidden">
      <img
        src={post.coverImage}
        alt={post.title}
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-black/20"></div>
    </div>
  </div>

  <!-- Conteúdo do Artigo -->
  <div class="max-w-3xl mx-auto px-4 md:px-6 -mt-16 relative z-10 pb-16">
    <!-- Card do artigo -->
    <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs text-gray-500">
          <li><a href="/" class="hover:text-emerald-600 transition-colors">Início</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li><a href="/blog" class="hover:text-emerald-600 transition-colors">Blog</a></li>
          <li><i class="ri-arrow-right-s-line"></i></li>
          <li class="text-gray-700 font-medium truncate max-w-xs">{post.title}</li>
        </ol>
      </nav>

      <!-- Categoria + Tempo de leitura -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">
          {post.category}
        </span>
        <span class="flex items-center gap-1 text-xs text-gray-500">
          <i class="ri-time-line"></i>
          {post.readTime} min de leitura
        </span>
        <span class="flex items-center gap-1 text-xs text-gray-500">
          <i class="ri-calendar-line"></i>
          {new Date(post.publishedAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
        </span>
      </div>

      <!-- Título -->
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-6 text-balance">
        {post.title}
      </h1>

      <!-- Autor -->
      <div class="flex items-center gap-3 pb-6 mb-8 border-b border-gray-100">
        <img
          src={post.authorImage}
          alt={post.author}
          class="w-10 h-10 rounded-full object-cover"
          loading="lazy"
        />
        <div>
          <p class="text-sm font-semibold text-gray-900">{post.author}</p>
          <p class="text-xs text-gray-500">{post.authorRole}</p>
        </div>
      </div>

      <!-- Conteúdo -->
      <div class="prose prose-gray prose-sm md:prose-base max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4
        prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-ul:text-gray-700 prose-li:my-1
        prose-strong:text-gray-900
        prose-a:text-emerald-600 prose-a:no-underline hover:prose-a:underline">
        <slot />
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-gray-100">
        {post.tags.map((tag) => (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
            #{tag}
          </span>
        ))}
      </div>

      <!-- Compartilhar -->
      <div class="mt-8 pt-6 border-t border-gray-100">
        <p class="text-sm font-semibold text-gray-700 mb-3">Compartilhar artigo:</p>
        <div class="flex gap-3">
          <a
            href={`https://wa.me/?text=${encodeURIComponent(`${post.title} — ${Astro.url.href}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-lg transition-colors"
          >
            <i class="ri-whatsapp-line"></i>
            WhatsApp
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors"
          >
            <i class="ri-linkedin-line"></i>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- CTA de Cadastro -->
    <div class="mt-8 bg-emerald-50 border border-emerald-200 rounded-2xl p-6 text-center">
      <h2 class="text-lg font-bold text-gray-900 mb-2">Pronto para dar o próximo passo?</h2>
      <p class="text-sm text-gray-600 mb-4">
        Cadastre-se gratuitamente e candidate-se às vagas em Santarém com segurança e anonimato.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/vagas" class="btn-secondary">
          <i class="ri-briefcase-line"></i>
          Ver Vagas
        </a>
        <button type="button" onclick="window.dispatchEvent(new CustomEvent('openRegisterModal'))" class="btn-primary">
          <i class="ri-user-add-line"></i>
          Criar conta grátis
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
